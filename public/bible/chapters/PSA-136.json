[
  {
    "id": "PSA.136.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 1,
    "text": "O give thanks unto the LORD; for {he is} good: for his mercy {endureth} for ever.",
    "hash": "4a3205c28e2c2cfaae20ff8b51d02c1776e003e44361c380df49a1d7902c9ff4"
  },
  {
    "id": "PSA.136.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 2,
    "text": "O give thanks unto the God of gods: for his mercy {endureth} for ever.",
    "hash": "34e58d19ab41fb26ab6da9c622a2dd90206220d4e02df36e4a40b97f6d9d3ae8"
  },
  {
    "id": "PSA.136.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 3,
    "text": "O give thanks to the Lord of lords: for his mercy {endureth} for ever.",
    "hash": "eae5d29a490b4626fe993775354ccb1bb39a65d568f72e3ffbd87c79a80b5b88"
  },
  {
    "id": "PSA.136.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 4,
    "text": "To him who alone doeth great wonders: for his mercy {endureth} for ever.",
    "hash": "f7915448750f0e39a46989877ebc3692713a2f525bc88cc8d0dea1ed75bbd7ca"
  },
  {
    "id": "PSA.136.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 5,
    "text": "To him that by wisdom made the heavens: for his mercy {endureth} for ever.",
    "hash": "7daf9aca2c035076f609f54b8f934d8435c0b6d61d09011a3765e65faf35d52b"
  },
  {
    "id": "PSA.136.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 6,
    "text": "To him that stretched out the earth above the waters: for his mercy {endureth} for ever.",
    "hash": "af1f3ffee7017d10487ab03e35f3e9aa91261a20040b1121fcd45f1028b3b685"
  },
  {
    "id": "PSA.136.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 7,
    "text": "To him that made great lights: for his mercy {endureth} for ever:",
    "hash": "f12e4236bb5ee9072b49f7cab890f83045893569c3f84580fbe6f17f1eaa3965"
  },
  {
    "id": "PSA.136.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 8,
    "text": "The sun to rule by day: for his mercy {endureth} for ever: {to rule...: Heb. for the rulings by day}",
    "hash": "0091abdaf52c0465edde56cfe33c60ec2c88075188dd32cf4d58c1d9242e0ea3"
  },
  {
    "id": "PSA.136.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 9,
    "text": "The moon and stars to rule by night: for his mercy {endureth} for ever.",
    "hash": "02a43d2ece97a41477b5e2cdbe5c9f2ef8b1d10ab698fcc98af46560e1423c95"
  },
  {
    "id": "PSA.136.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 10,
    "text": "To him that smote Egypt in their firstborn: for his mercy {endureth} for ever:",
    "hash": "e6046959318abfdef389d7abf625493a89d40b2a92d5ef04d8e690d775f0a0c6"
  },
  {
    "id": "PSA.136.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 11,
    "text": "And brought out Israel from among them: for his mercy {endureth} for ever:",
    "hash": "b3d991ef79c4bd1a51200cbd1916f7cc00d6589a6c04b363957381dc758c021b"
  },
  {
    "id": "PSA.136.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 12,
    "text": "With a strong hand, and with a stretched out arm: for his mercy {endureth} for ever.",
    "hash": "3034055b6083a328ac935b03bd749d09bb91c014510c6d17ea349242562535d8"
  },
  {
    "id": "PSA.136.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 13,
    "text": "To him which divided the Red sea into parts: for his mercy {endureth} for ever:",
    "hash": "b9fdb23e4201b6e718e46581594ee994af4b550e16be19d411da020c2c884a0a"
  },
  {
    "id": "PSA.136.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 14,
    "text": "And made Israel to pass through the midst of it: for his mercy {endureth} for ever:",
    "hash": "fb68d9b230c66e3b0bd0ab721fbd9564e68649538d5fe41a660471e353e993c7"
  },
  {
    "id": "PSA.136.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 15,
    "text": "But overthrew Pharaoh and his host in the Red sea: for his mercy {endureth} for ever. {overthrew: Heb. shaked off}",
    "hash": "b999fa99fe9c85ecc928b659dbaa96248228cf0d4bdf3abc608b191ceacb4a4c"
  },
  {
    "id": "PSA.136.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 16,
    "text": "To him which led his people through the wilderness: for his mercy {endureth} for ever.",
    "hash": "4bdd03a78802e4ad53c5d07df9e17ca983443a853db186c02d014b4516b6e44e"
  },
  {
    "id": "PSA.136.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 17,
    "text": "To him which smote great kings: for his mercy {endureth} for ever:",
    "hash": "637fc98f425a5335e304804e61ac5fb865aca6baa6f2a56a52916496886b454c"
  },
  {
    "id": "PSA.136.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 18,
    "text": "And slew famous kings: for his mercy {endureth} for ever:",
    "hash": "cd92e0b44dd0d2074f61256d21b322e69619a20a1571bad4bcc8fd0b58fb2369"
  },
  {
    "id": "PSA.136.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 19,
    "text": "Sihon king of the Amorites: for his mercy {endureth} for ever:",
    "hash": "a5a1c3ae9ec8e96b2e63e477872fb8306c9774c43c12bc0939b0b1f585832d69"
  },
  {
    "id": "PSA.136.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 20,
    "text": "And Og the king of Bashan: for his mercy {endureth} for ever:",
    "hash": "eb36165161fcb86baf1dc476f908c3a1f11da2ec28dabf4affab880dbaf47d15"
  },
  {
    "id": "PSA.136.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 21,
    "text": "And gave their land for an heritage: for his mercy {endureth} for ever:",
    "hash": "e6d8d1c5b01e0a990689e8aa23fe4cf50a6ddd9a4e20b257ecd0b83bce9d7897"
  },
  {
    "id": "PSA.136.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 22,
    "text": "{Even} an heritage unto Israel his servant: for his mercy {endureth} for ever.",
    "hash": "31e50312d2ab59f10d44ab1c08853dabecd3cd43168d2dbb10eda0c074e4d490"
  },
  {
    "id": "PSA.136.23",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 23,
    "text": "Who remembered us in our low estate: for his mercy {endureth} for ever:",
    "hash": "aa03ce088bd6d02eb3872d8fa8029791cf50e1c16a1711d36e1c4a72670c494c"
  },
  {
    "id": "PSA.136.24",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 24,
    "text": "And hath redeemed us from our enemies: for his mercy {endureth} for ever.",
    "hash": "a54d936de4b59fa2733ed325de6bdffc38cc38df842c208140c87c733d0260c1"
  },
  {
    "id": "PSA.136.25",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 25,
    "text": "Who giveth food to all flesh: for his mercy {endureth} for ever.",
    "hash": "f3e50ad327186f586a8d26ee2ce9a2f2b1c3d24edb90f6d52aef6bd99948b687"
  },
  {
    "id": "PSA.136.26",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 136,
    "verse": 26,
    "text": "O give thanks unto the God of heaven: for his mercy {endureth} for ever.",
    "hash": "1af1c21572ef088981ed0399b95c2f40de53d13a599855a574731824a9359a4f"
  }
]