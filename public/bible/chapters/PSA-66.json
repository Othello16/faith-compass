[
  {
    "id": "PSA.66.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 1,
    "text": "[To the chief Musician, A Song {or} Psalm.] Make a joyful noise unto God, all ye lands: {all...: Heb. all the earth}",
    "hash": "08693619feb07f0bdafa5198a71230b6590d1bf9ca92b24955a159b8c632f895"
  },
  {
    "id": "PSA.66.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 2,
    "text": "Sing forth the honour of his name: make his praise glorious.",
    "hash": "1958c8299bba5b02ccccc3ad6fcfa05934f7da0cb906e322cd22b1b09cbab136"
  },
  {
    "id": "PSA.66.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 3,
    "text": "Say unto God, How terrible {art thou in} thy works! through the greatness of thy power shall thine enemies submit themselves unto thee. {submit...: or, yield feigned obedience: Heb. lie}",
    "hash": "824bdcdddc47ba0026b1199e877c6c905cd68b950c34b6873f39066d3496b04c"
  },
  {
    "id": "PSA.66.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 4,
    "text": "All the earth shall worship thee, and shall sing unto thee; they shall sing {to} thy name. Selah.",
    "hash": "898dc06ebcb8bce0961118580f7b8be1b6eb5363260a586fcecf3f6058b35841"
  },
  {
    "id": "PSA.66.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 5,
    "text": "Come and see the works of God: {he is} terrible {in his} doing toward the children of men.",
    "hash": "ff5421a6eeb7e144fc1ef73f6fa1fdca9d48789c0d1c136f09e1ae020be075f7"
  },
  {
    "id": "PSA.66.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 6,
    "text": "He turned the sea into dry {land}: they went through the flood on foot: there did we rejoice in him.",
    "hash": "5aac5b1e80ad484b9e98404c1c558f09417daf5c83387f619364e6edb00eba78"
  },
  {
    "id": "PSA.66.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 7,
    "text": "He ruleth by his power for ever; his eyes behold the nations: let not the rebellious exalt themselves. Selah.",
    "hash": "030bf20352b77ebc89a7997e87cde8a72a36cd6c89ab3a700ced5b3177f580e3"
  },
  {
    "id": "PSA.66.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 8,
    "text": "O bless our God, ye people, and make the voice of his praise to be heard:",
    "hash": "c7fee797b7de3fdcca455d202b270c05636c95d12c0cd65913ea7db8a3611639"
  },
  {
    "id": "PSA.66.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 9,
    "text": "Which holdeth our soul in life, and suffereth not our feet to be moved. {holdeth: Heb. putteth}",
    "hash": "19b23295e4d684d1da4aceb29b65685ad152921ffcd94a74e95b3dd203e99e09"
  },
  {
    "id": "PSA.66.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 10,
    "text": "For thou, O God, hast proved us: thou hast tried us, as silver is tried.",
    "hash": "3efa06bf92c9d7de97660e13a5f73fec24c3f9cbb0ac04ceb19a413a22cf63c5"
  },
  {
    "id": "PSA.66.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 11,
    "text": "Thou broughtest us into the net; thou laidst affliction upon our loins.",
    "hash": "afae575267e8166adae22380bfcf2a61154337446f28269adc0806262b558412"
  },
  {
    "id": "PSA.66.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 12,
    "text": "Thou hast caused men to ride over our heads; we went through fire and through water: but thou broughtest us out into a wealthy {place}. {wealthy: Heb. moist}",
    "hash": "86695ad8b4880783dadac446f5bf0062bca31498748a05dc15f8dfea20800f93"
  },
  {
    "id": "PSA.66.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 13,
    "text": "I will go into thy house with burnt offerings: I will pay thee my vows,",
    "hash": "65f8cf0e32353d904b40d4f3e0cb8fd67a7c6debf7e213726e61937e0759b7f9"
  },
  {
    "id": "PSA.66.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 14,
    "text": "Which my lips have uttered, and my mouth hath spoken, when I was in trouble. {uttered: Heb. opened}",
    "hash": "f0deb879cfee6b986e30a46c37a233dc23778c7689cdcfbe0050f617776f670d"
  },
  {
    "id": "PSA.66.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 15,
    "text": "I will offer unto thee burnt sacrifices of fatlings, with the incense of rams; I will offer bullocks with goats. Selah. {fatlings: Heb. marrow}",
    "hash": "409d71daafb4fa2a24ec5a93f49c8b235cb0bb10104680b7e19752f3afb1da44"
  },
  {
    "id": "PSA.66.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 16,
    "text": "Come {and} hear, all ye that fear God, and I will declare what he hath done for my soul.",
    "hash": "17c1d4df848ef2b62c605f6471402c3159cbd4b5484f2529d61c97491ff970e5"
  },
  {
    "id": "PSA.66.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 17,
    "text": "I cried unto him with my mouth, and he was extolled with my tongue.",
    "hash": "e6cbf8fc787b7b1830a7b6d0ce0fc05525a4e16323a686482b7c200fa4925dbd"
  },
  {
    "id": "PSA.66.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 18,
    "text": "If I regard iniquity in my heart, the Lord will not hear {me}:",
    "hash": "e00a912c560aa169f4fa5f8439070dcb322e5dbf597e4223f6443c8148e84c91"
  },
  {
    "id": "PSA.66.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 19,
    "text": "{But} verily God hath heard {me}; he hath attended to the voice of my prayer.",
    "hash": "c02ef700ea5d1e54f783da1cf890a8547e8c7236739db222a98fc51ee3613b4a"
  },
  {
    "id": "PSA.66.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 66,
    "verse": 20,
    "text": "Blessed {be} God, which hath not turned away my prayer, nor his mercy from me.",
    "hash": "9c402e29a3c611eae48638d3ca55fa8f4d7964f0a0c580d770620132d1abcd6b"
  }
]