[
  {
    "id": "PSA.103.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 1,
    "text": "[{A Psalm} of David.] Bless the LORD, O my soul: and all that is within me, {bless} his holy name.",
    "hash": "1a99f70aef67584af8ae24e78d4838b1836e7bcef45cfeadebb2b691d2bdd707"
  },
  {
    "id": "PSA.103.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 2,
    "text": "Bless the LORD, O my soul, and forget not all his benefits:",
    "hash": "246010a30c9bfc8d0dc87335b49e2f829a4b4d9e5133296274bc6d25ee19f76b"
  },
  {
    "id": "PSA.103.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 3,
    "text": "Who forgiveth all thine iniquities; who healeth all thy diseases;",
    "hash": "1ac8d284bf9d94c0dc10d7ef8f65686eefff9dca9b7973636978c728ef230480"
  },
  {
    "id": "PSA.103.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 4,
    "text": "Who redeemeth thy life from destruction; who crowneth thee with lovingkindness and tender mercies;",
    "hash": "3cd7d68984b911caa4a804d0d3a5e345a9ee181a4c349d5cac2632567f820dbf"
  },
  {
    "id": "PSA.103.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 5,
    "text": "Who satisfieth thy mouth with good {things; so that} thy youth is renewed like the eagle's.",
    "hash": "565260ce957676b20b84f78621b5a971d413a7bb53c29da56d010b27890d8f3c"
  },
  {
    "id": "PSA.103.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 6,
    "text": "The LORD executeth righteousness and judgment for all that are oppressed.",
    "hash": "dd2523fd3fd9a48543f2ad1cddf8034d6e8264e99c7c0417571be89cee064311"
  },
  {
    "id": "PSA.103.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 7,
    "text": "He made known his ways unto Moses, his acts unto the children of Israel.",
    "hash": "b9441ca54b3d66ee7ffce08c20e6ec9d8e479b7d4f54e1bd09217fe7ab73ed85"
  },
  {
    "id": "PSA.103.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 8,
    "text": "The LORD {is} merciful and gracious, slow to anger, and plenteous in mercy. {plentious...: Heb. great in mercy}",
    "hash": "1bb527e6dead1d6aa4a57186a2fe3014f5e72a0c187b217b74fb0185d2511aeb"
  },
  {
    "id": "PSA.103.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 9,
    "text": "He will not always chide: neither will he keep {his anger} for ever.",
    "hash": "49d4c4c046db7c323d667319e32a05697bb891f0efa98440bbcaa1bf3a70b28e"
  },
  {
    "id": "PSA.103.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 10,
    "text": "He hath not dealt with us after our sins; nor rewarded us according to our iniquities.",
    "hash": "e43594e495b972f7236410c6815d505cfaeb1fd2a8764aca735b8af5ab0f446a"
  },
  {
    "id": "PSA.103.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 11,
    "text": "For as the heaven is high above the earth, {so} great is his mercy toward them that fear him. {as...: Heb. according to the height of the heaven}",
    "hash": "338bd24cf64102f28f1cac5ecf95cd1274bd21cb3471c07a151d81d3cf6647f5"
  },
  {
    "id": "PSA.103.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 12,
    "text": "As far as the east is from the west, {so} far hath he removed our transgressions from us.",
    "hash": "692904de6f7b437994e03b1e51a117f98c170e8bdb27b542479d35e0939a784f"
  },
  {
    "id": "PSA.103.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 13,
    "text": "Like as a father pitieth {his} children, {so} the LORD pitieth them that fear him.",
    "hash": "e10761d7c47c1336460467d8e5aa7e6f5a39127f79878ea604b96974147fd3ed"
  },
  {
    "id": "PSA.103.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 14,
    "text": "For he knoweth our frame; he remembereth that we {are} dust.",
    "hash": "4228b2e4821fe714630c79e22036e014b6a519a998b4550229090f97cf0d6b45"
  },
  {
    "id": "PSA.103.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 15,
    "text": "{As for} man, his days {are} as grass: as a flower of the field, so he flourisheth.",
    "hash": "ceeb16cf536d9779b01b31addaa368324af84fb191dabaeae347b229f43a2e0e"
  },
  {
    "id": "PSA.103.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 16,
    "text": "For the wind passeth over it, and it is gone; and the place thereof shall know it no more. {it is...: Heb. it is not}",
    "hash": "f81a6df74e49e9b967517a28a467c8c335bfa8166d4f02d58b96142a3edb8236"
  },
  {
    "id": "PSA.103.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 17,
    "text": "But the mercy of the LORD {is} from everlasting to everlasting upon them that fear him, and his righteousness unto children's children;",
    "hash": "1b374ebac9e90ffac94cd24f3fdedb10ec2e4fbe94a6272bfb516fffa3036352"
  },
  {
    "id": "PSA.103.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 18,
    "text": "To such as keep his covenant, and to those that remember his commandments to do them.",
    "hash": "1d51896da420dd5cafd12a666af1690f0be3d69c9bc3c1a65c89059ac91fd2e5"
  },
  {
    "id": "PSA.103.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 19,
    "text": "The LORD hath prepared his throne in the heavens; and his kingdom ruleth over all.",
    "hash": "a3a804105746d9d8645386924ab2724f82ed271f1d26a6dd1a581bc3c9eca5ad"
  },
  {
    "id": "PSA.103.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 20,
    "text": "Bless the LORD, ye his angels, that excel in strength, that do his commandments, hearkening unto the voice of his word. {that excel...: Heb. mighty in strength}",
    "hash": "90aec93a335452a2717e03a9d53817d1bc113b6d3cb78097653f76ea35c5ccb5"
  },
  {
    "id": "PSA.103.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 21,
    "text": "Bless ye the LORD, all {ye} his hosts; {ye} ministers of his, that do his pleasure.",
    "hash": "c1e4eb499fa9fed7f82012d5454f69aa5830a4baa44bd3272d5b3a1ce0117d64"
  },
  {
    "id": "PSA.103.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 103,
    "verse": 22,
    "text": "Bless the LORD, all his works in all places of his dominion: bless the LORD, O my soul.",
    "hash": "deb0bb7f853023f5fe9303265d3d29e699688780d4ff2a87c28259f2b3116ebd"
  }
]