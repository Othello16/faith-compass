[
  {
    "id": "PSA.94.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 1,
    "text": "O LORD God, to whom vengeance belongeth; O God, to whom vengeance belongeth, shew thyself. {God...: Heb. God of revenges} {shew...: Heb. shine forth}",
    "hash": "43077e4d181017e960e6cd56a8645df198a853007b4d28493e2bc90bd655a442"
  },
  {
    "id": "PSA.94.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 2,
    "text": "Lift up thyself, thou judge of the earth: render a reward to the proud.",
    "hash": "36d8350e3043e3b0b6206c18172a36654b3492580d5f9f01de6bf01489901037"
  },
  {
    "id": "PSA.94.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 3,
    "text": "LORD, how long shall the wicked, how long shall the wicked triumph?",
    "hash": "e59e109bf35c6e3966a42eedb0efa616beaec68dfc1c7f8e43323000d80e4285"
  },
  {
    "id": "PSA.94.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 4,
    "text": "{How long} shall they utter {and} speak hard things? {and} all the workers of iniquity boast themselves?",
    "hash": "125f8409fe1b837c13f597eed6de9dc2765e0cb3f364365fa8befcb4c4e43e3f"
  },
  {
    "id": "PSA.94.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 5,
    "text": "They break in pieces thy people, O LORD, and afflict thine heritage.",
    "hash": "766606d492254e9612b2aa39e9d3673d2be8f01c4d7b305d90a2e0faf7afa2af"
  },
  {
    "id": "PSA.94.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 6,
    "text": "They slay the widow and the stranger, and murder the fatherless.",
    "hash": "838a0354b6426802de4dd6bffa2d0e0f4d15598321c02bbf7793056099ed85e7"
  },
  {
    "id": "PSA.94.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 7,
    "text": "Yet they say, The LORD shall not see, neither shall the God of Jacob regard {it}.",
    "hash": "912b2b7143c9446423ede32d2a5574bcd5af900e72861aaebea2ba71b80d343b"
  },
  {
    "id": "PSA.94.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 8,
    "text": "Understand, ye brutish among the people: and {ye} fools, when will ye be wise?",
    "hash": "7184db1cc078e32600aa56a761b1bf90345b5d60ed85ad75bf0c92ddd57047cf"
  },
  {
    "id": "PSA.94.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 9,
    "text": "He that planted the ear, shall he not hear? he that formed the eye, shall he not see?",
    "hash": "520b5711316f00e9f4e4876efef16425259c94d16926844979715b9250751717"
  },
  {
    "id": "PSA.94.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 10,
    "text": "He that chastiseth the heathen, shall not he correct? he that teacheth man knowledge, {shall not he know}?",
    "hash": "ff37cc4fd295f050d1f23ab2e3d74489e5b333b5adb85ce01fc0e78f0a1aeb4f"
  },
  {
    "id": "PSA.94.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 11,
    "text": "The LORD knoweth the thoughts of man, that they {are} vanity.",
    "hash": "93f7f3035009d479b19707a159b6c3a5c25860165280646b0b4fe75bfa8fda92"
  },
  {
    "id": "PSA.94.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 12,
    "text": "Blessed {is} the man whom thou chastenest, O LORD, and teachest him out of thy law;",
    "hash": "f3890859c3d00fffc8c5f44fe1f0e99aaa67e519c08005d1e00588ba2e04420d"
  },
  {
    "id": "PSA.94.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 13,
    "text": "That thou mayest give him rest from the days of adversity, until the pit be digged for the wicked.",
    "hash": "ac24d4d9877148763ecdbaa1e7be5863aca7084459a74189fe95e45996b95d67"
  },
  {
    "id": "PSA.94.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 14,
    "text": "For the LORD will not cast off his people, neither will he forsake his inheritance.",
    "hash": "fdde793d1261ff59d57b7fa7c30e4ee532e62d57743b2ea415cbe5973ce013dc"
  },
  {
    "id": "PSA.94.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 15,
    "text": "But judgment shall return unto righteousness: and all the upright in heart shall follow it. {shall follow...: Heb. shall be after it}",
    "hash": "39485405071c2e6d3659cf2c2947a3998cd0a2a179f798363cc0f6a6b50012b0"
  },
  {
    "id": "PSA.94.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 16,
    "text": "Who will rise up for me against the evildoers? {or} who will stand up for me against the workers of iniquity?",
    "hash": "01d8d99824abd9560f6228efa33de8726c0f7cc13e525c4e13fde0d8fa49b4d1"
  },
  {
    "id": "PSA.94.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 17,
    "text": "Unless the LORD {had been} my help, my soul had almost dwelt in silence. {almost: or, quickly}",
    "hash": "6a0b20a81bf9c013154c055656e28d2ce3f6b57fde0b880dd2b742b24447cd41"
  },
  {
    "id": "PSA.94.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 18,
    "text": "When I said, My foot slippeth; thy mercy, O LORD, held me up.",
    "hash": "b97bb061f2db154230a5d9b7d45ab3de96aa559d420948d20b1e76bbe411d705"
  },
  {
    "id": "PSA.94.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 19,
    "text": "In the multitude of my thoughts within me thy comforts delight my soul.",
    "hash": "3f5f0d99008c703442187cd4a1c2d35a22c22790b371af56189795098537646a"
  },
  {
    "id": "PSA.94.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 20,
    "text": "Shall the throne of iniquity have fellowship with thee, which frameth mischief by a law?",
    "hash": "f56c65f951ce0f9a235e598c81354a654dca63fb5493b1528acfe69edfafe7a2"
  },
  {
    "id": "PSA.94.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 21,
    "text": "They gather themselves together against the soul of the righteous, and condemn the innocent blood.",
    "hash": "d26547ecb31fca55a29567da1c1d76fd5430fe8b1a42b75591a1fcaf7deeda3c"
  },
  {
    "id": "PSA.94.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 22,
    "text": "But the LORD is my defence; and my God {is} the rock of my refuge.",
    "hash": "7a0fd268494157dbd26957b6225804fbd29d69f4accc1d60a2c68be3b8ebea5a"
  },
  {
    "id": "PSA.94.23",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 94,
    "verse": 23,
    "text": "And he shall bring upon them their own iniquity, and shall cut them off in their own wickedness; {yea}, the LORD our God shall cut them off.",
    "hash": "35341fc20040afc5753b9200484898a348049ea9bb77d67ea3f13d33f8a8e8be"
  }
]