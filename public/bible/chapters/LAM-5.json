[
  {
    "id": "LAM.5.1",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 1,
    "text": "Remember, O LORD, what is come upon us: consider, and behold our reproach.",
    "hash": "fe7186fd21ab5157e0620235574cbddf396114f117fe08a0949c7732cbc43463"
  },
  {
    "id": "LAM.5.2",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 2,
    "text": "Our inheritance is turned to strangers, our houses to aliens.",
    "hash": "3ebea1dbe58feb3dccc0af3d673d6c34feb8498e526c7a5fbf66df30197cb1da"
  },
  {
    "id": "LAM.5.3",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 3,
    "text": "We are orphans and fatherless, our mothers {are} as widows.",
    "hash": "560fc431b0997da54af117a80605af6a25c826c5123be87b09d769eb08493bf0"
  },
  {
    "id": "LAM.5.4",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 4,
    "text": "We have drunken our water for money; our wood is sold unto us. {is...: Heb. cometh for price}",
    "hash": "0d25d124aadfcaeebed84e07ba7ff798f12cdaecaa7c0c20504ba875d6fe8b62"
  },
  {
    "id": "LAM.5.5",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 5,
    "text": "Our necks {are} under persecution: we labour, {and} have no rest. {Our...: Heb. On our necks are we persecuted}",
    "hash": "fb09b3c883aa96b0aa0a1a51480eb4101897a097d82d7aa7a7607874d77e0325"
  },
  {
    "id": "LAM.5.6",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 6,
    "text": "We have given the hand {to} the Egyptians, {and to} the Assyrians, to be satisfied with bread.",
    "hash": "8b30d10d55445b263e0c0c0d2e184f8b4ae3bcb401058a2a879dc8f9ef41429e"
  },
  {
    "id": "LAM.5.7",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 7,
    "text": "Our fathers have sinned, {and are} not; and we have borne their iniquities.",
    "hash": "9912cd67086c1272bcdf16d9ea562ae8f8fa8059499dcc3ef186ce1a95afb86d"
  },
  {
    "id": "LAM.5.8",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 8,
    "text": "Servants have ruled over us: {there is} none that doth deliver {us} out of their hand.",
    "hash": "b8f5c3eebe5ffd2927b1b7a63359fa5a70ce45d15d27e6eb5be43e6b0a558341"
  },
  {
    "id": "LAM.5.9",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 9,
    "text": "We gat our bread with {the peril of} our lives because of the sword of the wilderness.",
    "hash": "2065e2b0fe13d5a8631091221f98834292317f0d1c25702a825d3aec8bd131e8"
  },
  {
    "id": "LAM.5.10",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 10,
    "text": "Our skin was black like an oven because of the terrible famine. {terrible: or, terrors, or, storms}",
    "hash": "0acf81331392d02e71431437c14604f96b547d67bfe216b92526a57bf66eeab9"
  },
  {
    "id": "LAM.5.11",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 11,
    "text": "They ravished the women in Zion, {and} the maids in the cities of Judah.",
    "hash": "7dc28a56be86c3c95fd1405b50cf0e3f4bd326e81b3a73a0df52868076f12bc1"
  },
  {
    "id": "LAM.5.12",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 12,
    "text": "Princes are hanged up by their hand: the faces of elders were not honoured.",
    "hash": "75206d4891e0547cb21b55b3f0a235463a9f5881184189afeb0a408b5e58d0e8"
  },
  {
    "id": "LAM.5.13",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 13,
    "text": "They took the young men to grind, and the children fell under the wood.",
    "hash": "ddc6470f1cc4326ce48bcac8d4f929a6225858b8c744e55449cdb655c5c31382"
  },
  {
    "id": "LAM.5.14",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 14,
    "text": "The elders have ceased from the gate, the young men from their musick.",
    "hash": "7b522ebaba0af528e7ece5f4bcf0fce0cd6afa30fe5571707e82ec364fa77a97"
  },
  {
    "id": "LAM.5.15",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 15,
    "text": "The joy of our heart is ceased; our dance is turned into mourning.",
    "hash": "8052429baa7038e923b8b94651b2209fc4870b14c0f617a42c59c26bdceba405"
  },
  {
    "id": "LAM.5.16",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 16,
    "text": "The crown is fallen {from} our head: woe unto us, that we have sinned! {The...: Heb. The crown of our head is fallen}",
    "hash": "bb52d8f696103527336f3fe5a77d9f6593217e6985d85c5bac03e54d5ae664c5"
  },
  {
    "id": "LAM.5.17",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 17,
    "text": "For this our heart is faint; for these {things} our eyes are dim.",
    "hash": "a8c5f85ee91db955bec339c7a7f1a4f6ea2f43d03fb4299f8030994190f058cf"
  },
  {
    "id": "LAM.5.18",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 18,
    "text": "Because of the mountain of Zion, which is desolate, the foxes walk upon it.",
    "hash": "33d90ef72f9f8f1189ef394713ceaab3cf65d2500ab3bee8b3eb9ed980a3414c"
  },
  {
    "id": "LAM.5.19",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 19,
    "text": "Thou, O LORD, remainest for ever; thy throne from generation to generation.",
    "hash": "c1e4f02d14f0e70ddb6e06893ec48d0f6eaab2e38c3cd70d23039f51870dcc80"
  },
  {
    "id": "LAM.5.20",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 20,
    "text": "Wherefore dost thou forget us for ever, {and} forsake us so long time? {so...: Heb. for length of days?}",
    "hash": "c0cd11b2273344206f83c32a0b97dd809aa5e685f711f84d8ea3ee657852a2a0"
  },
  {
    "id": "LAM.5.21",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 21,
    "text": "Turn thou us unto thee, O LORD, and we shall be turned; renew our days as of old.",
    "hash": "446af1594bd14113ab651592a0fefe2849cc7afff09710da7b4b105168e68873"
  },
  {
    "id": "LAM.5.22",
    "book": "Lamentations",
    "bookNum": 25,
    "bookAbbrev": "LAM",
    "chapter": 5,
    "verse": 22,
    "text": "But thou hast utterly rejected us; thou art very wroth against us. {But...: or, For wilt thou utterly reject us?}",
    "hash": "aba98ed973d949f91ca33d20d2d1c11e4517a0f9caf5efd6f0402bf35c62c3b0"
  }
]