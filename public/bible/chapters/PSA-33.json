[
  {
    "id": "PSA.33.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 1,
    "text": "Rejoice in the LORD, O ye righteous: {for} praise is comely for the upright.",
    "hash": "854722054f3034b98f442f2b94f683048607b45e690e4d1c60fdc6045c2ef51b"
  },
  {
    "id": "PSA.33.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 2,
    "text": "Praise the LORD with harp: sing unto him with the psaltery {and} an instrument of ten strings.",
    "hash": "087db00f9bdddbe46e6fac66e5b73f9b1bb02e43e5026ddaddeba68c7570f15c"
  },
  {
    "id": "PSA.33.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 3,
    "text": "Sing unto him a new song; play skilfully with a loud noise.",
    "hash": "c81ac3b753a3573c2357dbeaf222362c27cf9706e96bce2597e4599b0439dbb7"
  },
  {
    "id": "PSA.33.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 4,
    "text": "For the word of the LORD {is} right; and all his works {are done} in truth.",
    "hash": "e53c8b1c24ab574feaddceafa94083ba83973663e4700a809d925dc9c8300944"
  },
  {
    "id": "PSA.33.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 5,
    "text": "He loveth righteousness and judgment: the earth is full of the goodness of the LORD. {goodness: or, mercy}",
    "hash": "5ca5311662bfe8f281be4fb34383b66cbb18291e486b5bcb79ac6039bff4e31b"
  },
  {
    "id": "PSA.33.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 6,
    "text": "By the word of the LORD were the heavens made; and all the host of them by the breath of his mouth.",
    "hash": "19278b65e72d8d5d9f893cdd867981640f03dec3bcfdf655d174354c8709dfd0"
  },
  {
    "id": "PSA.33.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 7,
    "text": "He gathereth the waters of the sea together as an heap: he layeth up the depth in storehouses.",
    "hash": "ee9947d528b390a6cea5ff81a90a6ac70e27273c683721f1150d7e979617813f"
  },
  {
    "id": "PSA.33.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 8,
    "text": "Let all the earth fear the LORD: let all the inhabitants of the world stand in awe of him.",
    "hash": "9a9f8ce6475c1c09e643fcffe591d028b28fc0f679aaa3cfbcdddb56653047b7"
  },
  {
    "id": "PSA.33.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 9,
    "text": "For he spake, and it was {done}; he commanded, and it stood fast.",
    "hash": "35f12398eca08f7b5265d8b95d8b3165cf3f8a7fd4d2fdfff58ca0f421372f77"
  },
  {
    "id": "PSA.33.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 10,
    "text": "The LORD bringeth the counsel of the heathen to nought: he maketh the devices of the people of none effect. {bringeth: Heb. maketh frustrate}",
    "hash": "e6a69357683ef6d17eaae70bd18ee1ad21403ed12cf53ff0027f8dcd4e4667a9"
  },
  {
    "id": "PSA.33.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 11,
    "text": "The counsel of the LORD standeth for ever, the thoughts of his heart to all generations. {to all...: Heb. to generation and generation}",
    "hash": "09f1f0ca1ff116083ae26b4bc2584a0980e1d3f0184074497cd1cbbe93481b1c"
  },
  {
    "id": "PSA.33.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 12,
    "text": "Blessed {is} the nation whose God {is} the LORD; {and} the people {whom} he hath chosen for his own inheritance.",
    "hash": "ab4c608b13486f8214c73ea80bbf205a80ea92a81f6952f97e813464e32e8519"
  },
  {
    "id": "PSA.33.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 13,
    "text": "The LORD looketh from heaven; he beholdeth all the sons of men.",
    "hash": "75e0fed241931893bd68f40b6aa51900c14ab4d3e00485724b8e98fe2181ec19"
  },
  {
    "id": "PSA.33.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 14,
    "text": "From the place of his habitation he looketh upon all the inhabitants of the earth.",
    "hash": "44bd3cf57d85d223f19efe304b41dd6db05924f440f1c88f8d6881ef5dee2b13"
  },
  {
    "id": "PSA.33.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 15,
    "text": "He fashioneth their hearts alike; he considereth all their works.",
    "hash": "8bb66abafadd98427341121bb59ffa2a64556b71ea4747367184219646229f03"
  },
  {
    "id": "PSA.33.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 16,
    "text": "There is no king saved by the multitude of an host: a mighty man is not delivered by much strength.",
    "hash": "fe4011129c88a70caa170112ee1bcd4e6092efaffe8b74c17037591db154e4ec"
  },
  {
    "id": "PSA.33.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 17,
    "text": "An horse {is} a vain thing for safety: neither shall he deliver {any} by his great strength.",
    "hash": "280a6040b2c27b5c25f5c3beb69b453e1e2f9c99a8a7690f4f4ae84b668f9e7d"
  },
  {
    "id": "PSA.33.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 18,
    "text": "Behold, the eye of the LORD {is} upon them that fear him, upon them that hope in his mercy;",
    "hash": "43fe663a090cc21bf5f0c95bd460e1885724d409116cbf271594745ab146509e"
  },
  {
    "id": "PSA.33.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 19,
    "text": "To deliver their soul from death, and to keep them alive in famine.",
    "hash": "4bdf5cbd5489f63e9e047dc5f3de65bf465679f995a7012967fcbb386ed3b763"
  },
  {
    "id": "PSA.33.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 20,
    "text": "Our soul waiteth for the LORD: he {is} our help and our shield.",
    "hash": "d8af8ec954c17ad9603397e880749dc20f27cad08aaeebf8f691e9723b771160"
  },
  {
    "id": "PSA.33.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 21,
    "text": "For our heart shall rejoice in him, because we have trusted in his holy name.",
    "hash": "ce8c588565ca83c3112cf1f48ac334908a490e9f6a756b5f5a3d2df0b5b855b3"
  },
  {
    "id": "PSA.33.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 33,
    "verse": 22,
    "text": "Let thy mercy, O LORD, be upon us, according as we hope in thee.",
    "hash": "910d2941ff54b3f19333a86140490e9752f2d9bb83bd8dcf98087e7be63012f5"
  }
]