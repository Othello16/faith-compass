  {
    "id": "PRO.14.34",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 34,
    "text": "Righteousness exalteth a nation: but sin {is} a reproach to any people. {to any...: Heb. to nations}",
