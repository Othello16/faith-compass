  },
  {
    "id": "PRO.14.5",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 5,
    "text": "A faithful witness will not lie: but a false witness will utter lies.",
