  },
  {
    "id": "PRO.14.24",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 24,
    "text": "The crown of the wise {is} their riches: {but} the foolishness of fools {is} folly.",
