  },
  {
    "id": "PRO.14.25",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 25,
    "text": "A true witness delivereth souls: but a deceitful {witness} speaketh lies.",
    "hash": "4e1bdc03da9dd0d2adead787bad90704d7a945cfda3ade4200f6a8abfd006339"
  },
  {
    "id": "PRO.14.26",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 26,
