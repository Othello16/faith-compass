  },
  {
    "id": "PRO.14.35",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 35,
    "text": "The king's favour {is} toward a wise servant: but his wrath is {against} him that causeth shame.",
    "hash": "9d5795b1deacefa42850cec5cd79009de70348017e6711aa623150d6b7237ea3"
  }
]