  },
  {
    "id": "PRO.14.29",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 29,
    "text": "{He that is} slow to wrath {is} of great understanding: but {he that is} hasty of spirit exalteth folly. {hasty...: Heb. short of spirit}",
    "hash": "5463a61ffedcdeb863bbf5985545ade080dc8ad963c90926c68b90a2dfc2b6e6"
  },
  {
    "id": "PRO.14.30",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 30,
    "text": "A sound heart {is} the life of the flesh: but envy the rottenness of the bones.",
    "hash": "734251af00bcb9e3781b165b0b8f1055a7d3684d6e7a967f81a75ab08042eca0"
  },
  {
    "id": "PRO.14.31",
    "book": "Proverbs",
    "bookNum": 20,
