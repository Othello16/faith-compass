[
  {
    "id": "PRO.14.1",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 14,
    "verse": 1,
    "text": "Every wise woman buildeth her house: but the foolish plucketh it down with her hands.",
    "hash": "e530bd4c8af12999d1fe1c9f47b4281011c546a3badd0f7ef08cc48f510f434b"
  },
  {
