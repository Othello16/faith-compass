[
  {
    "id": "PSA.25.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 1,
    "text": "[{A Psalm} of David.] Unto thee, O LORD, do I lift up my soul.",
    "hash": "26355f1a3087956cbc7854784c42507e11576348b255bdad7a5eb8c90ad56f16"
  },
  {
    "id": "PSA.25.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 2,
    "text": "O my God, I trust in thee: let me not be ashamed, let not mine enemies triumph over me.",
    "hash": "035a6bf0092df0e0401644197b6b60ae70e45d67b8bf41cc42346ec4cf8eed21"
  },
  {
    "id": "PSA.25.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 3,
    "text": "Yea, let none that wait on thee be ashamed: let them be ashamed which transgress without cause.",
    "hash": "8ff48f9a965e24f3b438454b7edbcae4d70df09761c850789271f2c538e27aec"
  },
  {
    "id": "PSA.25.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 4,
    "text": "Shew me thy ways, O LORD; teach me thy paths.",
    "hash": "cc1f8f67f33896f994cccb093c455901afeb393f15bb56f519449d934e81d1be"
  },
  {
    "id": "PSA.25.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 5,
    "text": "Lead me in thy truth, and teach me: for thou {art} the God of my salvation; on thee do I wait all the day.",
    "hash": "d1fefec53ba1ee7dadad7d92734c678b03853567b085b6c00aa584f7fa4a3e4e"
  },
  {
    "id": "PSA.25.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 6,
    "text": "Remember, O LORD, thy tender mercies and thy lovingkindnesses; for they {have been} ever of old. {tender...: Heb. bowels}",
    "hash": "87b07fc4616fc3a06d5825efaf0739787dbb132752af5efdeb97f3fb904f8fd9"
  },
  {
    "id": "PSA.25.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 7,
    "text": "Remember not the sins of my youth, nor my transgressions: according to thy mercy remember thou me for thy goodness' sake, O LORD.",
    "hash": "8e0b455803fd6d12166c54aadc8a7174d6ed985b4a2ca009653027b05b6de6ba"
  },
  {
    "id": "PSA.25.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 8,
    "text": "Good and upright {is} the LORD: therefore will he teach sinners in the way.",
    "hash": "6ff34d4c173a95f51fadc5f537edfa7554729c1d36c9330a6a27b7ee529077cf"
  },
  {
    "id": "PSA.25.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 9,
    "text": "The meek will he guide in judgment: and the meek will he teach his way.",
    "hash": "c875db74c61f689aa4dadf7322968504c4bfb078ae4d297643079dd8383b522f"
  },
  {
    "id": "PSA.25.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 10,
    "text": "All the paths of the LORD {are} mercy and truth unto such as keep his covenant and his testimonies.",
    "hash": "a199fa242d881df6312ec50efc6a10d92869ed07b5996ad4f91bc76087787d3a"
  },
  {
    "id": "PSA.25.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 11,
    "text": "For thy name's sake, O LORD, pardon mine iniquity; for it {is} great.",
    "hash": "53e42901af719b3d3059e0a74e2fd13c86cd84b0526c2d03bfdb193ecbb5989f"
  },
  {
    "id": "PSA.25.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 12,
    "text": "What man {is} he that feareth the LORD? him shall he teach in the way {that} he shall choose.",
    "hash": "dc7d6a6c95ff1475b3c10e6e50ceb74ff9579415fd2ceab718ff9c7b16b560df"
  },
  {
    "id": "PSA.25.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 13,
    "text": "His soul shall dwell at ease; and his seed shall inherit the earth. {dwell...: Heb. lodge in goodness}",
    "hash": "dcfb1e0721cd33940d9d1dc5dd59adde5770223d50d85a79f315c90ddc0c50bb"
  },
  {
    "id": "PSA.25.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 14,
    "text": "The secret of the LORD {is} with them that fear him; and he will shew them his covenant. {and...: or, and his covenant to make them know it}",
    "hash": "a0400d91df87a30a56a4d9481302322e86644a4e0036f655604cee4f78a61491"
  },
  {
    "id": "PSA.25.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 15,
    "text": "Mine eyes {are} ever toward the LORD; for he shall pluck my feet out of the net. {pluck: Heb. bring forth}",
    "hash": "901e3c0f3df27065b77de83f5651676881399a0469bd2513522706ef85a3eb40"
  },
  {
    "id": "PSA.25.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 16,
    "text": "Turn thee unto me, and have mercy upon me; for I {am} desolate and afflicted.",
    "hash": "4806270e99b6af80df20a238b5ca39bc4e9105c0b95c29dad3357e47e287dc8a"
  },
  {
    "id": "PSA.25.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 17,
    "text": "The troubles of my heart are enlarged: {O} bring thou me out of my distresses.",
    "hash": "c439803e9eb50933265b53bc16c238ec6c168403bf6a9a5f289f37766b6d7d3d"
  },
  {
    "id": "PSA.25.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 18,
    "text": "Look upon mine affliction and my pain; and forgive all my sins.",
    "hash": "4c936675f54ffbf1c5d2bc04539149ea92ad8a8d8452b33454d755580a85db57"
  },
  {
    "id": "PSA.25.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 19,
    "text": "Consider mine enemies; for they are many; and they hate me with cruel hatred. {cruel...: Heb. hatred of violence}",
    "hash": "a4c66ef1ce4a26f1ece3b9ec2f5b3d5a25479127282e8708058e41e94cfa2574"
  },
  {
    "id": "PSA.25.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 20,
    "text": "O keep my soul, and deliver me: let me not be ashamed; for I put my trust in thee.",
    "hash": "5b60bf4c61dc2a626d2b59bf1f44a1747ef19c07c9cd6dcf4142faf2d5afd91d"
  },
  {
    "id": "PSA.25.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 21,
    "text": "Let integrity and uprightness preserve me; for I wait on thee.",
    "hash": "051d5797b2ce606ef47f34cf5ee52869d5ce3878438def99f318ce2c52e077e9"
  },
  {
    "id": "PSA.25.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 25,
    "verse": 22,
    "text": "Redeem Israel, O God, out of all his troubles.",
    "hash": "be494a02ee97fe913449f882861aa3578be6eb7bb98f56bedb263324be83bd95"
  }
]