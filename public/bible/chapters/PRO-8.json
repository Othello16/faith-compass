[
  {
    "id": "PRO.8.1",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 1,
    "text": "Doth not wisdom cry? and understanding put forth her voice?",
    "hash": "8bf84e8204309d84dcb209d6f813ed46ea5020743be95dca239d9383e4ab8bd2"
  },
  {
    "id": "PRO.8.2",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 2,
    "text": "She standeth in the top of high places, by the way in the places of the paths.",
    "hash": "4c4bc2e08a9f5c5db0f0299f0430d80251699fe64faaebb4e8fdea287fa3f50b"
  },
  {
    "id": "PRO.8.3",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 3,
    "text": "She crieth at the gates, at the entry of the city, at the coming in at the doors.",
    "hash": "1f260f8413c558645236e88e61f8fb1012e2f580269fdb8a21e08192e0f211f4"
  },
  {
    "id": "PRO.8.4",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 4,
    "text": "Unto you, O men, I call; and my voice {is} to the sons of man.",
    "hash": "9eac6ac4aa8d5b9b3f7d700dbf41469ba94150c48aa0046a353d5681243df059"
  },
  {
    "id": "PRO.8.5",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 5,
    "text": "O ye simple, understand wisdom: and, ye fools, be ye of an understanding heart.",
    "hash": "d3227ca321e36a1fb88321d579139d3aee232d786dca0c50a8f5623b8128c632"
  },
  {
    "id": "PRO.8.6",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 6,
    "text": "Hear; for I will speak of excellent things; and the opening of my lips {shall be} right things.",
    "hash": "24f79b2d7e58112caf0113337dfd533a9d7e1e0d9d6692beb1cf0882e8edb07f"
  },
  {
    "id": "PRO.8.7",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 7,
    "text": "For my mouth shall speak truth; and wickedness {is} an abomination to my lips. {an...: Heb. the abomination of my lips}",
    "hash": "4412fee88916aedc514542862e1dbbba79d111ecf581beff2759b768906c6126"
  },
  {
    "id": "PRO.8.8",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 8,
    "text": "All the words of my mouth {are} in righteousness; {there is} nothing froward or perverse in them. {froward: Heb. wreathed}",
    "hash": "11f290bb5771f27ee9b9686e3825af22e995ad4f30f7240d1d5d59504e532607"
  },
  {
    "id": "PRO.8.9",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 9,
    "text": "They {are} all plain to him that understandeth, and right to them that find knowledge.",
    "hash": "b9c1ccdd7c3b7356af4445efcdee21ee80b1b54e5703fd4cf160f90095919da4"
  },
  {
    "id": "PRO.8.10",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 10,
    "text": "Receive my instruction, and not silver; and knowledge rather than choice gold.",
    "hash": "a8b37e2ce47f9f007616904a021b998185842cc956ec01c2c57f11d105cc4441"
  },
  {
    "id": "PRO.8.11",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 11,
    "text": "For wisdom {is} better than rubies; and all the things that may be desired are not to be compared to it.",
    "hash": "e0d2ee3c04a7edc4a4e536be8d9550b4b516a2c96155a41b83be148972de5d43"
  },
  {
    "id": "PRO.8.12",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 12,
    "text": "I wisdom dwell with prudence, and find out knowledge of witty inventions. {prudence: or, subtilty}",
    "hash": "ab49f66470a7a78dbe0b1c053df4205c643e23cae41d6308924432f2776dbdab"
  },
  {
    "id": "PRO.8.13",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 13,
    "text": "The fear of the LORD {is} to hate evil: pride, and arrogancy, and the evil way, and the froward mouth, do I hate.",
    "hash": "5de993f152ac897d99e473773d3490ee8f180314752c4024f187122dd90f91dd"
  },
  {
    "id": "PRO.8.14",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 14,
    "text": "Counsel {is} mine, and sound wisdom: I {am} understanding; I have strength.",
    "hash": "58ebabf4dc68c66e1e1c6f9d185137a3955f4d6f907957e5ded6cdc0d6a3953a"
  },
  {
    "id": "PRO.8.15",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 15,
    "text": "By me kings reign, and princes decree justice.",
    "hash": "cf10910667beb61754cf0be07ece3d5368b5703d7832770d7384d8dccc15fd57"
  },
  {
    "id": "PRO.8.16",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 16,
    "text": "By me princes rule, and nobles, {even} all the judges of the earth.",
    "hash": "a5cde42ed82082ec23520d47e3e9d57a443af2021682c761118655689767b240"
  },
  {
    "id": "PRO.8.17",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 17,
    "text": "I love them that love me; and those that seek me early shall find me.",
    "hash": "6df5ab5176da6bee11e6c8eaec22e24af82a81d594da570c0de7fbe73c4c411e"
  },
  {
    "id": "PRO.8.18",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 18,
    "text": "Riches and honour {are} with me; {yea}, durable riches and righteousness.",
    "hash": "af4261f7816c60511cd28bd84af0a38a4c93d2d45256eb7e3f14b77639c65d22"
  },
  {
    "id": "PRO.8.19",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 19,
    "text": "My fruit {is} better than gold, yea, than fine gold; and my revenue than choice silver.",
    "hash": "546b5f09e3d92d6efdfa6126fa1045b028f8380b1833ac3cd5626688cb13182b"
  },
  {
    "id": "PRO.8.20",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 20,
    "text": "I lead in the way of righteousness, in the midst of the paths of judgment: {lead: or, walk}",
    "hash": "adc7de0608a024a6701465369434f08dc7fd2d2207f5dfb0e2b5478312ea2af1"
  },
  {
    "id": "PRO.8.21",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 21,
    "text": "That I may cause those that love me to inherit substance; and I will fill their treasures.",
    "hash": "d42c3ba64fd1d3477d94b102dbd442057740ed12794caadcc2f45961b90f6942"
  },
  {
    "id": "PRO.8.22",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 22,
    "text": "The LORD possessed me in the beginning of his way, before his works of old.",
    "hash": "fd1dd40250f4454ec081a647e01a2fc12c43535b17387759a823c3f3c4363e93"
  },
  {
    "id": "PRO.8.23",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 23,
    "text": "I was set up from everlasting, from the beginning, or ever the earth was.",
    "hash": "9b927b6efa12b7da4191daf00b87ba29295b29284b9547aaa6f2867c80d801e2"
  },
  {
    "id": "PRO.8.24",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 24,
    "text": "When {there were} no depths, I was brought forth; when {there were} no fountains abounding with water.",
    "hash": "53c6b054ec32bd6b3590136472e8f1cbd51922532e034067a07634ea9aa602ab"
  },
  {
    "id": "PRO.8.25",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 25,
    "text": "Before the mountains were settled, before the hills was I brought forth:",
    "hash": "57f6db73aff8477d6b116b43c9a89f28ff4c4417c9ffe7a0002a3269e08b90be"
  },
  {
    "id": "PRO.8.26",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 26,
    "text": "While as yet he had not made the earth, nor the fields, nor the highest part of the dust of the world. {fields: or, open places} {the highest...: or, the chief part}",
    "hash": "dd079fa768f5717e574b5dd0adfb8bf79c6fbde53b97d0f4872f7a5afaa0c5d8"
  },
  {
    "id": "PRO.8.27",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 27,
    "text": "When he prepared the heavens, I {was} there: when he set a compass upon the face of the depth: {a compass: or, a circle}",
    "hash": "16959d5d5c5d55bbf685595010376603ff141bb99561c336020ba730aa29163a"
  },
  {
    "id": "PRO.8.28",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 28,
    "text": "When he established the clouds above: when he strengthened the fountains of the deep:",
    "hash": "fec39519a16f0be1564644c4f34ff5aa3d0973fd486f42e07f4fc0fa2013c7d4"
  },
  {
    "id": "PRO.8.29",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 29,
    "text": "When he gave to the sea his decree, that the waters should not pass his commandment: when he appointed the foundations of the earth:",
    "hash": "75e49189b0edf0852d24f8c4cd0c1490b2a65aa56dab79da88fb15a80930706b"
  },
  {
    "id": "PRO.8.30",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 30,
    "text": "Then I was by him, {as} one brought up {with him}: and I was daily {his} delight, rejoicing always before him;",
    "hash": "ae3de471f9a9a7d318d85c248b55a5837de6ccb382f45f0cbae4a937dfea3722"
  },
  {
    "id": "PRO.8.31",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 31,
    "text": "Rejoicing in the habitable part of his earth; and my delights {were} with the sons of men.",
    "hash": "1cde43fcf529093cfdfd278922a56176144f17ad54971bdd43386a4eb9788573"
  },
  {
    "id": "PRO.8.32",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 32,
    "text": "Now therefore hearken unto me, O ye children: for blessed {are they that} keep my ways.",
    "hash": "a6bf33b98403f3baa0e106ac814a5fd289d819609981d5c2e04dc9cf1f6992a8"
  },
  {
    "id": "PRO.8.33",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 33,
    "text": "Hear instruction, and be wise, and refuse it not.",
    "hash": "114efa9ef91ca132f026fb24e15a2fd4867bd6d5ff0c675b8239c87ed1095987"
  },
  {
    "id": "PRO.8.34",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 34,
    "text": "Blessed {is} the man that heareth me, watching daily at my gates, waiting at the posts of my doors.",
    "hash": "fff8bd9a0e0b46b549a1473d3cdd95aaa92768b561b9f067b014e97a04c5e5af"
  },
  {
    "id": "PRO.8.35",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 35,
    "text": "For whoso findeth me findeth life, and shall obtain favour of the LORD. {obtain: Heb. bring forth}",
    "hash": "19c523153b46d9762ab8865929d0ab4eba8e0e9229bfa4406a84fb1eea3ada61"
  },
  {
    "id": "PRO.8.36",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 8,
    "verse": 36,
    "text": "But he that sinneth against me wrongeth his own soul: all they that hate me love death.",
    "hash": "94ddfe27631300e732dd110ee60dd753b220b3b87f6f07524386c5fe6637eb27"
  }
]