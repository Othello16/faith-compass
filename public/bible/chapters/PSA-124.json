[
  {
    "id": "PSA.124.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 1,
    "text": "[A Song of degrees of David.] If {it had not been} the LORD who was on our side, now may Israel say;",
    "hash": "e4ed0f35937e923a7b8540b1b5554009b074a8a5dfd32f2c59dbe1e944704c8e"
  },
  {
    "id": "PSA.124.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 2,
    "text": "If {it had not been} the LORD who was on our side, when men rose up against us:",
    "hash": "955b454792ea62b5e73540561136c4d17243afc70dfd90a881ac417273feb48d"
  },
  {
    "id": "PSA.124.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 3,
    "text": "Then they had swallowed us up quick, when their wrath was kindled against us:",
    "hash": "1ee81133cf2ea9a7ac8e7658e6558fdb26022c3bd4a7ac0e68165f4b0ecb97a4"
  },
  {
    "id": "PSA.124.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 4,
    "text": "Then the waters had overwhelmed us, the stream had gone over our soul:",
    "hash": "6fe0236d12591ba1d4b8656fde052a22c47fc493e33fe514f16bff004739fc63"
  },
  {
    "id": "PSA.124.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 5,
    "text": "Then the proud waters had gone over our soul.",
    "hash": "3b534ce13c7b7c6dd9af799df292e2d11cf7732ae78d2ae67b6ae496810180e6"
  },
  {
    "id": "PSA.124.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 6,
    "text": "Blessed {be} the LORD, who hath not given us {as} a prey to their teeth.",
    "hash": "b4cdc1c591c85826f2c83f42e69c25efdfc0dffee44144397f61e71d50ab7ac3"
  },
  {
    "id": "PSA.124.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 7,
    "text": "Our soul is escaped as a bird out of the snare of the fowlers: the snare is broken, and we are escaped.",
    "hash": "963b1932ace1b9090ccb1f9f383e2048c92ddec46d3f796311a7ab608a4c6fe1"
  },
  {
    "id": "PSA.124.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 124,
    "verse": 8,
    "text": "Our help {is} in the name of the LORD, who made heaven and earth.",
    "hash": "0a66e952248cff8ede9bf80ea79ce8f70adc2269dd63d8e86ede21745ce140a6"
  }
]