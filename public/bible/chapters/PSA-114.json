  },
  {
    "id": "PSA.114.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 114,
    "verse": 2,
    "text": "Judah was his sanctuary, {and} Israel his dominion.",
    "hash": "f7cea5c06169df75870488d1572b9187635475c0c14357480fd7713dff9d8fc7"
  },
  {
    "id": "PSA.114.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 114,
    "verse": 3,
    "text": "The sea saw {it}, and fled: Jordan was driven back.",
