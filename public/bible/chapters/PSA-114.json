    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 114,
    "verse": 4,
    "text": "The mountains skipped like rams, {and} the little hills like lambs.",
    "hash": "fedc0b9a680ea772bcc244aa1e4a5482fdc50256be5f087b41fbc862b3513949"
  },
  {
    "id": "PSA.114.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 114,
    "verse": 5,
    "text": "What {ailed} thee, O thou sea, that thou fleddest? thou Jordan, {that} thou wast driven back?",
