    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 114,
    "verse": 7,
    "text": "Tremble, thou earth, at the presence of the Lord, at the presence of the God of Jacob;",
    "hash": "a8ea3a6a4758fe9eb552a8a6a3bbc2ad599a1251cc4de4e5933c349eca4851c7"
