[
  {
    "id": "JOB.23.1",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 1,
    "text": "Then Job answered and said,",
    "hash": "3cea07ac5b3d5c27f3b87fb724c38fd8c32bf1ab9fa665f52a544060e851e318"
  },
  {
    "id": "JOB.23.2",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 2,
    "text": "Even to day {is} my complaint bitter: my stroke is heavier than my groaning. {stroke: Heb. hand}",
    "hash": "6249bf26c2c7ebe20b7953d0f2fbb73d3a8d346d0ad9738544c7c4d719813ea6"
  },
  {
    "id": "JOB.23.3",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 3,
    "text": "Oh that I knew where I might find him! {that} I might come {even} to his seat!",
    "hash": "ddbf145ae8859bb030edb1e612f274b7407478f698f64e3e1a9504aa07d9567e"
  },
  {
    "id": "JOB.23.4",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 4,
    "text": "I would order {my} cause before him, and fill my mouth with arguments.",
    "hash": "3d4415c5e2a6ecdc9fdbc4e1455a9a4e3b33a8c273744ac8954035666c7c4724"
  },
  {
    "id": "JOB.23.5",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 5,
    "text": "I would know the words {which} he would answer me, and understand what he would say unto me.",
    "hash": "78331f171838924e1a1d80b971855c0da1e5a2a520e9a2ca3066f17e9411bbed"
  },
  {
    "id": "JOB.23.6",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 6,
    "text": "Will he plead against me with {his} great power? No; but he would put {strength} in me.",
    "hash": "7eb2fd4662457019ce67d277f5c0030772b95482c1e8790861e7e7f82f41bc9e"
  },
  {
    "id": "JOB.23.7",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 7,
    "text": "There the righteous might dispute with him; so should I be delivered for ever from my judge.",
    "hash": "5dc6a37b845f36734e07dc7a1c3f3024db1824ce89accb1b06401441c0affa03"
  },
  {
    "id": "JOB.23.8",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 8,
    "text": "Behold, I go forward, but he {is} not {there}; and backward, but I cannot perceive him:",
    "hash": "d190ac7398334a7c401012c0b7abdfb45dee08b11637ebd3355e96d14b94d74a"
  },
  {
    "id": "JOB.23.9",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 9,
    "text": "On the left hand, where he doth work, but I cannot behold {him}: he hideth himself on the right hand, that I cannot see {him}:",
    "hash": "8b5e19afcfab3416d507a51118299055bf884c095ae88fe03dd0e88722459cd0"
  },
  {
    "id": "JOB.23.10",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 10,
    "text": "But he knoweth the way that I take: {when} he hath tried me, I shall come forth as gold. {that...: Heb. that is with me}",
    "hash": "1bc7932417ac577e94ff888109fc9ee8c0b29d9a06212e67c201228b9710ebbe"
  },
  {
    "id": "JOB.23.11",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 11,
    "text": "My foot hath held his steps, his way have I kept, and not declined.",
    "hash": "11152f3b7f6a530c3b80d8a0d00b69a9de25a1d520a56c407211b20f56dd7d89"
  },
  {
    "id": "JOB.23.12",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 12,
    "text": "Neither have I gone back from the commandment of his lips; I have esteemed the words of his mouth more than my necessary {food}. {esteemed: Heb. hid, or, laid up} {my...: or, my appointed portion}",
    "hash": "bde6a3b45adc0d48378c07c819adecaeed9d793fdbeb21f491b6d3e7033705a8"
  },
  {
    "id": "JOB.23.13",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 13,
    "text": "But he {is} in one {mind}, and who can turn him? and {what} his soul desireth, even {that} he doeth.",
    "hash": "10655ed58162f32a4ee783a4ffd723dff9a3ff553545c7637f9f9ee4491020bb"
  },
  {
    "id": "JOB.23.14",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 14,
    "text": "For he performeth {the thing that is} appointed for me: and many such {things are} with him.",
    "hash": "0285290bf151f75099e3946dfc021835a40f638396b00e7dde1b21ea2dc57ecc"
  },
  {
    "id": "JOB.23.15",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 15,
    "text": "Therefore am I troubled at his presence: when I consider, I am afraid of him.",
    "hash": "16138ace32163af0e139ae8dd9aa4f3b8491e706c95dfefcb653f1580741ee5d"
  },
  {
    "id": "JOB.23.16",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 16,
    "text": "For God maketh my heart soft, and the Almighty troubleth me:",
    "hash": "8acd7f9702a5738775d21f08c7bc7d6cd225dc4c9498485c01fe73d0122e326c"
  },
  {
    "id": "JOB.23.17",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 23,
    "verse": 17,
    "text": "Because I was not cut off before the darkness, {neither} hath he covered the darkness from my face.",
    "hash": "2cc27bacc446b592555f1de4c30fd07e59978a7d4f5ad98506eefddd329e9503"
  }
]