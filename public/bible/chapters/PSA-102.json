[
  {
    "id": "PSA.102.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 1,
    "text": "[A Prayer of the afflicted, when he is overwhelmed, and poureth out his complaint before the LORD.] Hear my prayer, O LORD, and let my cry come unto thee. {of: or, for}",
    "hash": "41a5900ae3bfa220fbf5f1ef5291afa1063dade8258283a05a276c41ae3c231c"
  },
  {
    "id": "PSA.102.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 2,
    "text": "Hide not thy face from me in the day {when} I am in trouble; incline thine ear unto me: in the day {when} I call answer me speedily.",
    "hash": "709a6044b0a1c226d37fa8d8432fa5b5a7f39b4350326fc08e05805b6ab3867d"
  },
  {
    "id": "PSA.102.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 3,
    "text": "For my days are consumed like smoke, and my bones are burned as an hearth. {like...: or, (as some read) into smoke}",
    "hash": "17457b18efbc4024572aa57a887da434706e8b95c98bc73e214d63fb51f113f1"
  },
  {
    "id": "PSA.102.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 4,
    "text": "My heart is smitten, and withered like grass; so that I forget to eat my bread.",
    "hash": "3620e43a339e7ca0f4213c638839fd056aa6eba59d865e4e56485752aa0f99ee"
  },
  {
    "id": "PSA.102.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 5,
    "text": "By reason of the voice of my groaning my bones cleave to my skin. {skin: or, flesh}",
    "hash": "04aac845131ee7b60e3bc1795abac5d8824c44f1126d5645aa5b656ff0448baa"
  },
  {
    "id": "PSA.102.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 6,
    "text": "I am like a pelican of the wilderness: I am like an owl of the desert.",
    "hash": "f26bf30a0a60ee8fc1f8345a68102a8f753d2085e58def242ea4a8a976b4ba60"
  },
  {
    "id": "PSA.102.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 7,
    "text": "I watch, and am as a sparrow alone upon the house top.",
    "hash": "ac68073a97595743dbd699932f55881983b23c111e1abf1dfd4331bb0f3dbca2"
  },
  {
    "id": "PSA.102.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 8,
    "text": "Mine enemies reproach me all the day; {and} they that are mad against me are sworn against me.",
    "hash": "147f06140de71bcdffde02365c250a9efc3714e26c49a3e3b9d9fa67d1bc7b09"
  },
  {
    "id": "PSA.102.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 9,
    "text": "For I have eaten ashes like bread, and mingled my drink with weeping,",
    "hash": "56ba65f8d944630db11309a9fd9587bcb84a8a7bfb16b69c0626d3b7f8668285"
  },
  {
    "id": "PSA.102.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 10,
    "text": "Because of thine indignation and thy wrath: for thou hast lifted me up, and cast me down.",
    "hash": "196d9da9a3a4ece4b488f339e5b7de0d98b338427ff116b69738822db10a9af6"
  },
  {
    "id": "PSA.102.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 11,
    "text": "My days {are} like a shadow that declineth; and I am withered like grass.",
    "hash": "7b9ca937e7c16194a2cec6a7c098d9448d324c1c1415ea69fc2bac4ad50cb68a"
  },
  {
    "id": "PSA.102.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 12,
    "text": "But thou, O LORD, shalt endure for ever; and thy remembrance unto all generations.",
    "hash": "cb83a3898dfbb0f5dea5411496a0159d8dbeab069186e5d372e4601860f77514"
  },
  {
    "id": "PSA.102.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 13,
    "text": "Thou shalt arise, {and} have mercy upon Zion: for the time to favour her, yea, the set time, is come.",
    "hash": "933906e260618f63fea971aab26ed16eb4f1048c3d3629129f01be1c362f140a"
  },
  {
    "id": "PSA.102.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 14,
    "text": "For thy servants take pleasure in her stones, and favour the dust thereof.",
    "hash": "7521587f4be4a7a92884fb6b831be044339209afb7b8e9c1ac3a6ae6bdd96abb"
  },
  {
    "id": "PSA.102.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 15,
    "text": "So the heathen shall fear the name of the LORD, and all the kings of the earth thy glory.",
    "hash": "ef0aef3d256adb8ffca11235c90255c2da61f39f350b4bac156031afce6feffb"
  },
  {
    "id": "PSA.102.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 16,
    "text": "When the LORD shall build up Zion, he shall appear in his glory.",
    "hash": "d2249400769f99cb77e3f45955da465934d3ba92ac1a18fd4b791122d50d77cc"
  },
  {
    "id": "PSA.102.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 17,
    "text": "He will regard the prayer of the destitute, and not despise their prayer.",
    "hash": "44da2bd2f95271773ad024ce9762cdba0d413ee23b0eb7eed0aeae72ab62fc52"
  },
  {
    "id": "PSA.102.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 18,
    "text": "This shall be written for the generation to come: and the people which shall be created shall praise the LORD.",
    "hash": "cc86dbda7dc251ac6e2cfd283cd10a392507400cac5a75dc9f82e7f031e5acf7"
  },
  {
    "id": "PSA.102.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 19,
    "text": "For he hath looked down from the height of his sanctuary; from heaven did the LORD behold the earth;",
    "hash": "68856ebbfd0bbaa3026e5c0c32ca8a79e0276fc5c7af8637e8b75befd2e14e6e"
  },
  {
    "id": "PSA.102.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 20,
    "text": "To hear the groaning of the prisoner; to loose those that are appointed to death; {those...: Heb. the children of death}",
    "hash": "6a20f5679ccf11ecfc6842e7d2a2f4ed8e7947fc58d99940abe652f44696d316"
  },
  {
    "id": "PSA.102.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 21,
    "text": "To declare the name of the LORD in Zion, and his praise in Jerusalem;",
    "hash": "d66c21f8c0c0af356757d54e2db87950c93dd684838ca82f47409a773288a002"
  },
  {
    "id": "PSA.102.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 22,
    "text": "When the people are gathered together, and the kingdoms, to serve the LORD.",
    "hash": "b78d255ba722529024c408a1098682758c1a0231276e8523d4929fba85df4f84"
  },
  {
    "id": "PSA.102.23",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 23,
    "text": "He weakened my strength in the way; he shortened my days. {weakened: Heb. afflicted}",
    "hash": "1dc60c9bf75969824b21dae9b99fdc427fb1ada5e73a5e7a8da4862e465f026d"
  },
  {
    "id": "PSA.102.24",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 24,
    "text": "I said, O my God, take me not away in the midst of my days: thy years {are} throughout all generations.",
    "hash": "cccad37bdb3a88800f7006cbc5c04f620a32d84859bc823bc017bc4e95be3d39"
  },
  {
    "id": "PSA.102.25",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 25,
    "text": "Of old hast thou laid the foundation of the earth: and the heavens {are} the work of thy hands.",
    "hash": "de982c82f1064893efb139c262c9b15209f06cc569284130a78a54b2b9a29e4b"
  },
  {
    "id": "PSA.102.26",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 26,
    "text": "They shall perish, but thou shalt endure: yea, all of them shall wax old like a garment; as a vesture shalt thou change them, and they shall be changed: {endure: Heb. stand}",
    "hash": "ca88d28611a01504e810f55af7a195c529854355185e02b5af0303f016a594a3"
  },
  {
    "id": "PSA.102.27",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 27,
    "text": "But thou {art} the same, and thy years shall have no end.",
    "hash": "d9ff9d6ace485117531b38f3348eb45f604e583304dc35b0822ed44b9ca781b3"
  },
  {
    "id": "PSA.102.28",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 102,
    "verse": 28,
    "text": "The children of thy servants shall continue, and their seed shall be established before thee.",
    "hash": "6184cd42635dd62ec8695e4677a445ca32c71ec7da5aa8372a9a2f853e7b558a"
  }
]