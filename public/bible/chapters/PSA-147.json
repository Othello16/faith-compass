[
  {
    "id": "PSA.147.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 1,
    "text": "Praise ye the LORD: for {it is} good to sing praises unto our God; for {it is} pleasant; {and} praise is comely.",
    "hash": "dce9528f4941b055f04ebee59172146c1bb5f4d3abbab4b260d7d454376d6298"
  },
  {
    "id": "PSA.147.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 2,
    "text": "The LORD doth build up Jerusalem: he gathereth together the outcasts of Israel.",
    "hash": "40092fb16474c3719c96c9176b562fa25b3faeb59442783eb4806048bd52d193"
  },
  {
    "id": "PSA.147.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 3,
    "text": "He healeth the broken in heart, and bindeth up their wounds. {wounds: Heb. griefs}",
    "hash": "f45ca9db1ed0c2e30785bcc8c197b22415d26f9984f573d564efefa930485bbc"
  },
  {
    "id": "PSA.147.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 4,
    "text": "He telleth the number of the stars; he calleth them all by {their} names.",
    "hash": "d324adcceabaecb939c358a6fdf713dea92edcde460600fd755f1f7d7042fa6b"
  },
  {
    "id": "PSA.147.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 5,
    "text": "Great {is} our Lord, and of great power: his understanding {is} infinite. {his...: Heb. of his understanding there is no number}",
    "hash": "e1902afc6dbb170238db012aeb7a2a2e82d8a92dcae36857b07e1de0f3eb7afa"
  },
  {
    "id": "PSA.147.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 6,
    "text": "The LORD lifteth up the meek: he casteth the wicked down to the ground.",
    "hash": "63935aa58f97f2006e1c2e005994343dbfb1dc02b0e954c7ed5f87f08aafad48"
  },
  {
    "id": "PSA.147.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 7,
    "text": "Sing unto the LORD with thanksgiving; sing praise upon the harp unto our God:",
    "hash": "eb2a90d75f6d91787a0939fc1fe1e2a5d9c4ccae3607e536891d718197d491ef"
  },
  {
    "id": "PSA.147.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 8,
    "text": "Who covereth the heaven with clouds, who prepareth rain for the earth, who maketh grass to grow upon the mountains.",
    "hash": "714d007d2c284478b4e7dc7c6e47e28c26a8882c69a91cfe408d1a05fed571fc"
  },
  {
    "id": "PSA.147.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 9,
    "text": "He giveth to the beast his food, {and} to the young ravens which cry.",
    "hash": "871d7c0d4e3c255fdd07326ceb416a2a752444f641edfbb849c04f4485573d55"
  },
  {
    "id": "PSA.147.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 10,
    "text": "He delighteth not in the strength of the horse: he taketh not pleasure in the legs of a man.",
    "hash": "91bf1638c77136bd1629b002c0fc1c105b65b26f6c6a0adcdddf55cb133f28ba"
  },
  {
    "id": "PSA.147.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 11,
    "text": "The LORD taketh pleasure in them that fear him, in those that hope in his mercy.",
    "hash": "99d669b47eac85a71259d72fd11b9aab436512d7811d11490d86edabffed7819"
  },
  {
    "id": "PSA.147.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 12,
    "text": "Praise the LORD, O Jerusalem; praise thy God, O Zion.",
    "hash": "b1da1215ca850be4960c4b3e65acff33a1b75d5620cff7a2640fa224cf617962"
  },
  {
    "id": "PSA.147.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 13,
    "text": "For he hath strengthened the bars of thy gates; he hath blessed thy children within thee.",
    "hash": "f4f2e05b009195daf44a44716e0b03d91e5024dbe09f204927c96a3d97c770d1"
  },
  {
    "id": "PSA.147.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 14,
    "text": "He maketh peace {in} thy borders, {and} filleth thee with the finest of the wheat. {He...: Heb. Who maketh thy border peace} {finest...: Heb. fat of wheat}",
    "hash": "dec7c08537fd2164da04112a59a4f98a7a21ef1154642bf589e3a07b970b8120"
  },
  {
    "id": "PSA.147.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 15,
    "text": "He sendeth forth his commandment {upon} earth: his word runneth very swiftly.",
    "hash": "d3abe5c30b7d6a2846b20aef0c3e70b4d373fa80eb69d6bf824a183b8b4e4be3"
  },
  {
    "id": "PSA.147.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 16,
    "text": "He giveth snow like wool: he scattereth the hoarfrost like ashes.",
    "hash": "43b84fdbc5fa961c880e125c83318be6554d63071d073175188e388d9b761470"
  },
  {
    "id": "PSA.147.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 17,
    "text": "He casteth forth his ice like morsels: who can stand before his cold?",
    "hash": "89cae8341bee18d9991ad9b8a855831903689fa467b38743c0d85859f8516164"
  },
  {
    "id": "PSA.147.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 18,
    "text": "He sendeth out his word, and melteth them: he causeth his wind to blow, {and} the waters flow.",
    "hash": "e9797a6dd6d899d369029a9c7f062e341906cc5e9db229ba57db8e667e154dd9"
  },
  {
    "id": "PSA.147.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 19,
    "text": "He sheweth his word unto Jacob, his statutes and his judgments unto Israel. {his word: Heb. his words}",
    "hash": "0fbae027c16b0c55462a5aa0f5d005ac251dc4b6529c2b1c336253c62ba21dce"
  },
  {
    "id": "PSA.147.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 147,
    "verse": 20,
    "text": "He hath not dealt so with any nation: and {as for his} judgments, they have not known them. Praise ye the LORD.",
    "hash": "58757c2676b4cc7b484ebea584194a149eb6bccce54d2f1574acc2233613a0ab"
  }
]