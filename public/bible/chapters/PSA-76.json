[
  {
    "id": "PSA.76.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 1,
    "text": "[To the chief Musician on Neginoth, A Psalm {or} Song of Asaph.] In Judah {is} God known: his name {is} great in Israel. {chief...: or, overseer} {of: or, for}",
    "hash": "c405ac5b2c411bc59519218df479f5a2ee6f1c33a1f53c0a191598bf2d649368"
  },
  {
    "id": "PSA.76.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 2,
    "text": "In Salem also is his tabernacle, and his dwelling place in Zion.",
    "hash": "1f1940912d6314558de51f4d4bb20b833f3aaff63aa0d37a93645ea06217123a"
  },
  {
    "id": "PSA.76.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 3,
    "text": "There brake he the arrows of the bow, the shield, and the sword, and the battle. Selah.",
    "hash": "236dc454bf7ca38d65ee6c8ff02c0c64f586624bcc6a2f9214aab630d8cf1561"
  },
  {
    "id": "PSA.76.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 4,
    "text": "Thou {art} more glorious {and} excellent than the mountains of prey.",
    "hash": "e3dfd4abc9f7622764aeb73aa60ef130e09cf9705999823584902075886a4136"
  },
  {
    "id": "PSA.76.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 5,
    "text": "The stouthearted are spoiled, they have slept their sleep: and none of the men of might have found their hands.",
    "hash": "d3b1c40922d42686a0a0b70b4bd03ea2908d3a184badb081b4a780328e14f265"
  },
  {
    "id": "PSA.76.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 6,
    "text": "At thy rebuke, O God of Jacob, both the chariot and horse are cast into a dead sleep.",
    "hash": "5eb1fd487b4f1f8d751d493e9a4165af186e19e639e0ac6ae912eb30ad878dfc"
  },
  {
    "id": "PSA.76.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 7,
    "text": "Thou, {even} thou, {art} to be feared: and who may stand in thy sight when once thou art angry?",
    "hash": "ad4f0802357a9b392ff19927c1478c59c5369dd9f2589abcea768e3732d53f01"
  },
  {
    "id": "PSA.76.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 8,
    "text": "Thou didst cause judgment to be heard from heaven; the earth feared, and was still,",
    "hash": "5f8ed101a5ecdb785744abdb2d44a873dcad1d0b1a233eae5cc0135716056a60"
  },
  {
    "id": "PSA.76.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 9,
    "text": "When God arose to judgment, to save all the meek of the earth. Selah.",
    "hash": "33c7e0d0b5745521d0a8d435f36e77076e2cf59389545e89b9693f074f48aff5"
  },
  {
    "id": "PSA.76.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 10,
    "text": "Surely the wrath of man shall praise thee: the remainder of wrath shalt thou restrain.",
    "hash": "e9ab6294c54c5eb0cb572cc51539d59f187be11dc70e21bbd5283a665d3f710e"
  },
  {
    "id": "PSA.76.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 11,
    "text": "Vow, and pay unto the LORD your God: let all that be round about him bring presents unto him that ought to be feared. {unto him...: Heb. to fear}",
    "hash": "8849476faab6120b1c5a4186228ee18ff3f3b423578e33d761da8e034b09546b"
  },
  {
    "id": "PSA.76.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 76,
    "verse": 12,
    "text": "He shall cut off the spirit of princes: {he is} terrible to the kings of the earth.",
    "hash": "5aa31a2368693619a774473794ff4e00bb65752e623cca12c045d3ee6a88138d"
  }
]