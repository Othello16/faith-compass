[
  {
    "id": "PSA.26.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 1,
    "text": "[{A Psalm} of David.] Judge me, O LORD; for I have walked in mine integrity: I have trusted also in the LORD; {therefore} I shall not slide.",
    "hash": "2c6e6935985cd70f879de7bda30f442560d0df2a9e13e6f684c457b63332bf01"
  },
  {
    "id": "PSA.26.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 2,
    "text": "Examine me, O LORD, and prove me; try my reins and my heart.",
    "hash": "841f3a31597f804e3b66c21d143e9b7b510db67f4f7e529674a007485d6b30eb"
  },
  {
    "id": "PSA.26.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 3,
    "text": "For thy lovingkindness {is} before mine eyes: and I have walked in thy truth.",
    "hash": "14add8918adb10ae1d7d817b2e42ff7768f4eb3ca28c6f54116b3bf36319d4ec"
  },
  {
    "id": "PSA.26.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 4,
    "text": "I have not sat with vain persons, neither will I go in with dissemblers.",
    "hash": "36a1d44106eb9fe371b889252624adaba0645e32b6a211b01de3434b39630c36"
  },
  {
    "id": "PSA.26.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 5,
    "text": "I have hated the congregation of evil doers; and will not sit with the wicked.",
    "hash": "a5b018573cfd5222fe6e706c49e7be71b5e18927fbeb5505a4c0a6c811684d4f"
  },
  {
    "id": "PSA.26.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 6,
    "text": "I will wash mine hands in innocency: so will I compass thine altar, O LORD:",
    "hash": "d9b2c77e48d71fd9cc5d1f2248558e1ac4e8618f572979e95b26f553bac2bbfa"
  },
  {
    "id": "PSA.26.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 7,
    "text": "That I may publish with the voice of thanksgiving, and tell of all thy wondrous works.",
    "hash": "17b782b5ec20d9a2844f14193bf4cf6f366cf0dc3918eca25ffd3e007c7c4ec2"
  },
  {
    "id": "PSA.26.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 8,
    "text": "LORD, I have loved the habitation of thy house, and the place where thine honour dwelleth. {where...: Heb. of the tabernacle of thy honour}",
    "hash": "b962c95d2d5cab5011b82c1045562764a674c8235c826fe1406f6d31c266d36a"
  },
  {
    "id": "PSA.26.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 9,
    "text": "Gather not my soul with sinners, nor my life with bloody men: {Gather...: or, Take not away} {bloody...: Heb. men of blood}",
    "hash": "c4e221d71efcd605a7ca0b5832984965c89f032f8ebc895581fe2b9682105f68"
  },
  {
    "id": "PSA.26.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 10,
    "text": "In whose hands {is} mischief, and their right hand is full of bribes. {full...: Heb. filled with}",
    "hash": "991b28c054e9bff0cfcd5ea701f85c349ff69e10fc510119ccc3e58d99a0e5fc"
  },
  {
    "id": "PSA.26.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 11,
    "text": "But as for me, I will walk in mine integrity: redeem me, and be merciful unto me.",
    "hash": "6d649b0cc484c3a47b8de12e8a02fc0884d8ab3fc21a6e5f19b2d647537fd731"
  },
  {
    "id": "PSA.26.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 26,
    "verse": 12,
    "text": "My foot standeth in an even place: in the congregations will I bless the LORD.",
    "hash": "64cad649e005ebd468947ea8fdb2c7d698bddb510762d25fd4325bd9e7b26ad7"
  }
]