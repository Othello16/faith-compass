[
  {
    "id": "PSA.107.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 1,
    "text": "O give thanks unto the LORD, for {he is} good: for his mercy {endureth} for ever.",
    "hash": "7a43f3388a8a4ab07f41ab12cb1a4ef7033011b2dd0c2bb214e59c7f4d1cd17c"
  },
  {
    "id": "PSA.107.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 2,
    "text": "Let the redeemed of the LORD say {so}, whom he hath redeemed from the hand of the enemy;",
    "hash": "335db51817be3eab5043d2cd2764cc32c41fd08fb2a03b50a5735e15ae04a445"
  },
  {
    "id": "PSA.107.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 3,
    "text": "And gathered them out of the lands, from the east, and from the west, from the north, and from the south. {south: Heb. sea}",
    "hash": "8dfac9d0b1c405552fe99acf958ef57d8bad2387abf8546ba3b131fc9f10093c"
  },
  {
    "id": "PSA.107.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 4,
    "text": "They wandered in the wilderness in a solitary way; they found no city to dwell in.",
    "hash": "7ba54b8e7d6ee0a87c58113ba658bc47215f09f6ecaa9ac1be5abbab270c0e67"
  },
  {
    "id": "PSA.107.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 5,
    "text": "Hungry and thirsty, their soul fainted in them.",
    "hash": "1407d4de0c85ba328e4374647299858841db3d87ffa85f3aabaa09a312eb4fe3"
  },
  {
    "id": "PSA.107.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 6,
    "text": "Then they cried unto the LORD in their trouble, {and} he delivered them out of their distresses.",
    "hash": "1ef28650d476d17b65c3522586d3ae6add1600e133a36cb49195094b0e92d11f"
  },
  {
    "id": "PSA.107.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 7,
    "text": "And he led them forth by the right way, that they might go to a city of habitation.",
    "hash": "871e6543bf2d199d1a2711e52974e15b956f8b118435f519cb52a88999428a42"
  },
  {
    "id": "PSA.107.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 8,
    "text": "Oh that {men} would praise the LORD {for} his goodness, and {for} his wonderful works to the children of men!",
    "hash": "62dfb49a39c9e7cd7bfee7594bfdd56b91e258b62a55af8f9636e05ab3111682"
  },
  {
    "id": "PSA.107.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 9,
    "text": "For he satisfieth the longing soul, and filleth the hungry soul with goodness.",
    "hash": "869e82970d44da5bafd4ebeb5f277ddeda561c0e36a5770c46daf017880b18e1"
  },
  {
    "id": "PSA.107.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 10,
    "text": "Such as sit in darkness and in the shadow of death, {being} bound in affliction and iron;",
    "hash": "2c69e79d21c15f929fcce25c61f452c4cb39779c7d56de38814d7861b7ea0310"
  },
  {
    "id": "PSA.107.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 11,
    "text": "Because they rebelled against the words of God, and contemned the counsel of the most High:",
    "hash": "1985f7a717d1b4e406bcc3695e9886c84dc88808bfd5c3ebd36a2b9116fc1485"
  },
  {
    "id": "PSA.107.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 12,
    "text": "Therefore he brought down their heart with labour; they fell down, and {there was} none to help.",
    "hash": "76a28906436e361a740f16beefbdb77cbf822f1350bf717e8eca73b9154cc6d4"
  },
  {
    "id": "PSA.107.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 13,
    "text": "Then they cried unto the LORD in their trouble, {and} he saved them out of their distresses.",
    "hash": "7ab6d734a2f9357beae8ec6ba2b82edb19ab783e3c409c9c17af89c43c16ade9"
  },
  {
    "id": "PSA.107.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 14,
    "text": "He brought them out of darkness and the shadow of death, and brake their bands in sunder.",
    "hash": "0681f8c40ef5a2106b18dc18bd9d9974c50ead353ce4c304453c5f9fa78886c0"
  },
  {
    "id": "PSA.107.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 15,
    "text": "Oh that {men} would praise the LORD {for} his goodness, and {for} his wonderful works to the children of men!",
    "hash": "62dfb49a39c9e7cd7bfee7594bfdd56b91e258b62a55af8f9636e05ab3111682"
  },
  {
    "id": "PSA.107.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 16,
    "text": "For he hath broken the gates of brass, and cut the bars of iron in sunder.",
    "hash": "10c360d1aaedf9afcdb353264efaabf62811e7204f08ce38585f5fdb6b7331b3"
  },
  {
    "id": "PSA.107.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 17,
    "text": "Fools because of their transgression, and because of their iniquities, are afflicted.",
    "hash": "02b781f08c7fc4b794eafb4ae50ec2e01010ef6b5daae1e7972f1fb1eb29ed1a"
  },
  {
    "id": "PSA.107.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 18,
    "text": "Their soul abhorreth all manner of meat; and they draw near unto the gates of death.",
    "hash": "1f59d3dd0d0b6d0d52b79a74a4825c2ec597a6d75fa784084372b599e63f990b"
  },
  {
    "id": "PSA.107.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 19,
    "text": "Then they cry unto the LORD in their trouble, {and} he saveth them out of their distresses.",
    "hash": "e55391922b817a93123ee728f36fa49b95f6947decf2f63f73cfe5e840b33532"
  },
  {
    "id": "PSA.107.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 20,
    "text": "He sent his word, and healed them, and delivered {them} from their destructions.",
    "hash": "8e87642199f6c9daf39641927c49b205378d8ea967ef709c8a4102fabca119c2"
  },
  {
    "id": "PSA.107.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 21,
    "text": "Oh that {men} would praise the LORD {for} his goodness, and {for} his wonderful works to the children of men!",
    "hash": "62dfb49a39c9e7cd7bfee7594bfdd56b91e258b62a55af8f9636e05ab3111682"
  },
  {
    "id": "PSA.107.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 22,
    "text": "And let them sacrifice the sacrifices of thanksgiving, and declare his works with rejoicing. {rejoicing: Heb. singing}",
    "hash": "05f6628b9f058ca0a221de75f9458172cac2d4b34052e40934754586b05ecc1a"
  },
  {
    "id": "PSA.107.23",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 23,
    "text": "They that go down to the sea in ships, that do business in great waters;",
    "hash": "abf1e97906b9c5c5f063733586c4adbdd21836f0abef218726a659b20c903db7"
  },
  {
    "id": "PSA.107.24",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 24,
    "text": "These see the works of the LORD, and his wonders in the deep.",
    "hash": "bbe25d9de019803df77f2101a79479d39402ea498e2b6da5b3fe6cc55836bda0"
  },
  {
    "id": "PSA.107.25",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 25,
    "text": "For he commandeth, and raiseth the stormy wind, which lifteth up the waves thereof. {raiseth: Heb. maketh to stand}",
    "hash": "738673c956b966181afd1262676cf85855a736a5b0a0c25397de1e95e1ef8040"
  },
  {
    "id": "PSA.107.26",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 26,
    "text": "They mount up to the heaven, they go down again to the depths: their soul is melted because of trouble.",
    "hash": "ff48a7c1c49409a8a21cf462f5c8c3e20e7978eed663149040e7dc29edb2c253"
  },
  {
    "id": "PSA.107.27",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 27,
    "text": "They reel to and fro, and stagger like a drunken man, and are at their wits' end. {are...: Heb. all their wisdom is swallowed up}",
    "hash": "ca34230a9de64ed52d2ef5a7c5e9fd681c113e69687104667a576cae00f09d91"
  },
  {
    "id": "PSA.107.28",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 28,
    "text": "Then they cry unto the LORD in their trouble, and he bringeth them out of their distresses.",
    "hash": "dfdbdc5ee17a63b8968526a3f4382e11733b0f41e98d952ab45697175773cf01"
  },
  {
    "id": "PSA.107.29",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 29,
    "text": "He maketh the storm a calm, so that the waves thereof are still.",
    "hash": "2326943ff5697fc9b887c32813fa49e0c6ca528f7320c1a218f7adb604357255"
  },
  {
    "id": "PSA.107.30",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 30,
    "text": "Then are they glad because they be quiet; so he bringeth them unto their desired haven.",
    "hash": "2e12e72d427b4c087f6c9223b44bac4418a1c599d942c5a13eb749d0f5ac91aa"
  },
  {
    "id": "PSA.107.31",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 31,
    "text": "Oh that {men} would praise the LORD {for} his goodness, and {for} his wonderful works to the children of men!",
    "hash": "62dfb49a39c9e7cd7bfee7594bfdd56b91e258b62a55af8f9636e05ab3111682"
  },
  {
    "id": "PSA.107.32",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 32,
    "text": "Let them exalt him also in the congregation of the people, and praise him in the assembly of the elders.",
    "hash": "c444ec6191df5c5812e7f2eafd32f34d9f0e7aa9f17dffba51c1f54a2376c2ce"
  },
  {
    "id": "PSA.107.33",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 33,
    "text": "He turneth rivers into a wilderness, and the watersprings into dry ground;",
    "hash": "c2ceeb9e979f70f8394d4961091d6a88f64c94b55d0b777ba42a2d59558bcdcb"
  },
  {
    "id": "PSA.107.34",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 34,
    "text": "A fruitful land into barrenness, for the wickedness of them that dwell therein. {barrenness: Heb. saltiness}",
    "hash": "ed8d8e833e09e726e3510328aa21033251294bb1c3f1338d8b687ecbdf806956"
  },
  {
    "id": "PSA.107.35",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 35,
    "text": "He turneth the wilderness into a standing water, and dry ground into watersprings.",
    "hash": "a3318d9f3111847a1c6c81b2a7627097d0c2c31351bd6cf542bbbc20fb7acbf8"
  },
  {
    "id": "PSA.107.36",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 36,
    "text": "And there he maketh the hungry to dwell, that they may prepare a city for habitation;",
    "hash": "84fbf0aed8b9baef39a37e4837bfc883296808fd80dd338e9821a2b907856bd5"
  },
  {
    "id": "PSA.107.37",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 37,
    "text": "And sow the fields, and plant vineyards, which may yield fruits of increase.",
    "hash": "56701e502e4289e1b5e87bca206948d5726b7996fd186f75a3ac8ae630a56cef"
  },
  {
    "id": "PSA.107.38",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 38,
    "text": "He blesseth them also, so that they are multiplied greatly; and suffereth not their cattle to decrease.",
    "hash": "ff7e1af5081ac89d2fbb108e79f348f44802adf9c7651a4606dcceb7d22aab06"
  },
  {
    "id": "PSA.107.39",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 39,
    "text": "Again, they are minished and brought low through oppression, affliction, and sorrow.",
    "hash": "a0a7147339a073978b3b787dec47e45db005ba76a517ba2af35c992c00f2676c"
  },
  {
    "id": "PSA.107.40",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 40,
    "text": "He poureth contempt upon princes, and causeth them to wander in the wilderness, {where there is} no way. {wilderness: or, void place}",
    "hash": "f86554cdf0114bdc91c35d566cbff4a65c73bd1ac16bc5dac5595d2bf3c5767a"
  },
  {
    "id": "PSA.107.41",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 41,
    "text": "Yet setteth he the poor on high from affliction, and maketh {him} families like a flock. {from: or, after}",
    "hash": "3eb9cb7ab14e9e8c226eb867062c19d1d9439ef3ce74be66c4bdeeddba91e039"
  },
  {
    "id": "PSA.107.42",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 42,
    "text": "The righteous shall see {it}, and rejoice: and all iniquity shall stop her mouth.",
    "hash": "0997be029fd5b4bf3774a64f2af33126747cffb8d0dd21b47561a2013256ea78"
  },
  {
    "id": "PSA.107.43",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 107,
    "verse": 43,
    "text": "Whoso {is} wise, and will observe these {things}, even they shall understand the lovingkindness of the LORD.",
    "hash": "150526dcded57d16726a88c43b1449bcffd51a2fc4bbfaf28ad1bcc6aa36d3e6"
  }
]