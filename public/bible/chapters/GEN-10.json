  },
  {
    "id": "GEN.10.11",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 11,
    "text": "Out of that land went forth Asshur, and builded Nineveh, and the city Rehoboth, and Calah, {went...: or, he went out into Assyria} {the city...: or, the streets of the city}",
    "hash": "07c48683c29f43ec988d60ededb11e8691755b5fc59b7d4c62e3f6f98b53e790"
  },
  {
    "id": "GEN.10.12",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 12,
    "text": "And Resen between Nineveh and Calah: the same {is} a great city.",
    "hash": "776a9c452f099ae7fa59ed079901a091ae28279aaf8fe05938d6e49fe3846d56"
  },
  {
    "id": "GEN.10.13",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 13,
    "text": "And Mizraim begat Ludim, and Anamim, and Lehabim, and Naphtuhim,",
    "hash": "1dcb9ab5c027e74a2e8b32dc906874120617bb88a704b4098d60dcbca56df0db"
  },
  {
    "id": "GEN.10.14",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 14,
    "text": "And Pathrusim, and Casluhim, (out of whom came Philistim,) and Caphtorim.",
    "hash": "b401cb7e1c507a53c1b0bf74c93999d40d378a07c9cb5bd55392465789850058"
  },
  {
    "id": "GEN.10.15",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 15,
    "text": "And Canaan begat Sidon his firstborn, and Heth, {Sidon: Heb. Tzidon}",
