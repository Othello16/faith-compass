[
  {
    "id": "GEN.10.1",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 1,
    "text": "Now these {are} the generations of the sons of Noah, Shem, Ham, and Japheth: and unto them were sons born after the flood.",
    "hash": "89c357a09aa7cf017b4c387609ea2b20c68a2fb72ca232ceb7849aa2ec1c9b90"
  },
  {
    "id": "GEN.10.2",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 2,
    "text": "The sons of Japheth; Gomer, and Magog, and Madai, and Javan, and Tubal, and Meshech, and Tiras.",
    "hash": "fa4fdff9ed1db4656702991202d6bf60dc73b3fdfe8ac7ba9785780378a908af"
  },
  {
    "id": "GEN.10.3",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 3,
    "text": "And the sons of Gomer; Ashkenaz, and Riphath, and Togarmah.",
    "hash": "20d42e23909363ac4ac9d9e9f5f0ddc5a9cd8d0860aeafb7c3086e24f9987438"
  },
  {
    "id": "GEN.10.4",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 4,
    "text": "And the sons of Javan; Elishah, and Tarshish, Kittim, and Dodanim. {Dodanim: or, as some read it, Rodanim}",
    "hash": "595abde0c62428d8a2c48f7acb42f962858427564e4abfff4ca07a8d9a90401e"
  },
  {
    "id": "GEN.10.5",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 5,
    "text": "By these were the isles of the Gentiles divided in their lands; every one after his tongue, after their families, in their nations.",
    "hash": "a3a5ebbf887148270aa0fb050daef3ace4d56455078f526b22c18fcc6229a2a9"
  },
  {
    "id": "GEN.10.6",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 6,
    "text": "And the sons of Ham; Cush, and Mizraim, and Phut, and Canaan.",
    "hash": "026c863ba0d06132871ef4441e3508765c5a507842bbd4d27fc1f3f92be05c76"
  },
  {
    "id": "GEN.10.7",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 7,
    "text": "And the sons of Cush; Seba, and Havilah, and Sabtah, and Raamah, and Sabtecha: and the sons of Raamah; Sheba, and Dedan.",
    "hash": "26328adb71d9b8ef927ca383220443505f570e0705cb3bb8fd0394caf1455e60"
  },
  {
    "id": "GEN.10.8",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 8,
    "text": "And Cush begat Nimrod: he began to be a mighty one in the earth.",
    "hash": "9be43d6787103175daf587fe1a55e91fcb10eb442d252970cc69db958bfb8c2c"
  },
  {
    "id": "GEN.10.9",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 9,
    "text": "He was a mighty hunter before the LORD: wherefore it is said, Even as Nimrod the mighty hunter before the LORD.",
    "hash": "03aa9660fd5a036b18ab22ef31efbfc1ff3adae2d22a80592da27449c3c9f5f6"
  },
  {
    "id": "GEN.10.10",
    "book": "Genesis",
    "bookNum": 1,
    "bookAbbrev": "GEN",
    "chapter": 10,
    "verse": 10,
    "text": "And the beginning of his kingdom was Babel, and Erech, and Accad, and Calneh, in the land of Shinar. {Babel: Gr. Babylon}",
