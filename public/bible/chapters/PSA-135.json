[
  {
    "id": "PSA.135.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 1,
    "text": "Praise ye the LORD. Praise ye the name of the LORD; praise {him}, O ye servants of the LORD.",
    "hash": "18c650a7afadb7e6a8ae2c0e314e1e8d6a04254d5ccaca1f1b900395faa9f201"
  },
  {
    "id": "PSA.135.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 2,
    "text": "Ye that stand in the house of the LORD, in the courts of the house of our God,",
    "hash": "e9c7329c44a34a3f5863c9bee941930f34e2f6c4b73d2c58b1a7b417bccb292a"
  },
  {
    "id": "PSA.135.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 3,
    "text": "Praise the LORD; for the LORD {is} good: sing praises unto his name; for {it is} pleasant.",
    "hash": "d603bef907fb83f37b11c241467ef3e276a0c45d07341f27c1ae27cbf8e2a56d"
  },
  {
    "id": "PSA.135.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 4,
    "text": "For the LORD hath chosen Jacob unto himself, {and} Israel for his peculiar treasure.",
    "hash": "8cfb35a60c42c2daced8d49895d4a47d76fb0a54b01bc0953f5d4e817da35cf0"
  },
  {
    "id": "PSA.135.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 5,
    "text": "For I know that the LORD {is} great, and {that} our Lord {is} above all gods.",
    "hash": "977b1185c42474782cb423edfcdace25d4db7c540440a1c7c1f683e3e8ee50ab"
  },
  {
    "id": "PSA.135.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 6,
    "text": "Whatsoever the LORD pleased, {that} did he in heaven, and in earth, in the seas, and all deep places.",
    "hash": "3b6f0fc3abdb7fa00295c5c413dd31afd87eed817c6faf91d7ae940f038a4ce0"
  },
  {
    "id": "PSA.135.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 7,
    "text": "He causeth the vapours to ascend from the ends of the earth; he maketh lightnings for the rain; he bringeth the wind out of his treasuries.",
    "hash": "b4f27fe08f3832d5ad928666b8789c7508f843b06ada99721eccf921975c6ec4"
  },
  {
    "id": "PSA.135.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 8,
    "text": "Who smote the firstborn of Egypt, both of man and beast. {both...: Heb. from man unto beast}",
    "hash": "3f00161992ebc23804f108aa340279b1a15cd1136b6e221708a663c60313c716"
  },
  {
    "id": "PSA.135.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 9,
    "text": "{Who} sent tokens and wonders into the midst of thee, O Egypt, upon Pharaoh, and upon all his servants.",
    "hash": "0a1c43bcea4587188021085a91b4cb6a38e2a087aa930bb0edd6615cd7bce393"
  },
  {
    "id": "PSA.135.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 10,
    "text": "Who smote great nations, and slew mighty kings;",
    "hash": "950ec912f493997134d6e0adc61955c19083f586ef703d4af187d2eb5fd96b56"
  },
  {
    "id": "PSA.135.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 11,
    "text": "Sihon king of the Amorites, and Og king of Bashan, and all the kingdoms of Canaan:",
    "hash": "89bbc459b593dc9c5cc553ecd8f6c9bc6d01814316d5331dcc15f993a7143137"
  },
  {
    "id": "PSA.135.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 12,
    "text": "And gave their land {for} an heritage, an heritage unto Israel his people.",
    "hash": "222f5e4d22a87aab17abfb9a42251eac35c822d21077fc097e6c5824903709d4"
  },
  {
    "id": "PSA.135.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 13,
    "text": "Thy name, O LORD, {endureth} for ever; {and} thy memorial, O LORD, throughout all generations. {throughout...: Heb. to generation and generation}",
    "hash": "d7f9cbb62608ac9b84d1b0222849105edb552e6a364e179c0384a3e35ddf60d9"
  },
  {
    "id": "PSA.135.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 14,
    "text": "For the LORD will judge his people, and he will repent himself concerning his servants.",
    "hash": "c95c13696d6b25e7704282e3f776c95297ce98d9bec24ee1969e2ae729c6ef05"
  },
  {
    "id": "PSA.135.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 15,
    "text": "The idols of the heathen {are} silver and gold, the work of men's hands.",
    "hash": "c6980da9ca44476065874dd9018d4e87934e2f564894986daa159ebd460e33bc"
  },
  {
    "id": "PSA.135.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 16,
    "text": "They have mouths, but they speak not; eyes have they, but they see not;",
    "hash": "92f60ce069bb5cbc7c54cf62248f7998c2710710bb3e48e646ab8ed4e9308fa0"
  },
  {
    "id": "PSA.135.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 17,
    "text": "They have ears, but they hear not; neither is there {any} breath in their mouths.",
    "hash": "c460ae1f627eeedbf6190f1436e6ef39f8f85f1e5b3eba9625cd0ce622f7bb66"
  },
  {
    "id": "PSA.135.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 18,
    "text": "They that make them are like unto them: {so is} every one that trusteth in them.",
    "hash": "db6c8fa06b7535349f3781e6f655f7cc091b830076ed1d1a4eb1e0b64bae0c54"
  },
  {
    "id": "PSA.135.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 19,
    "text": "Bless the LORD, O house of Israel: bless the LORD, O house of Aaron:",
    "hash": "537db7f47d54d0da64bec271e7c5a7f5eb64b1b4c3eb906561d63f69daa14b3f"
  },
  {
    "id": "PSA.135.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 20,
    "text": "Bless the LORD, O house of Levi: ye that fear the LORD, bless the LORD.",
    "hash": "5a518025916d23cbe700f8841e500975f8ffc397070a811f5f4f9c32a03e8f8a"
  },
  {
    "id": "PSA.135.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 135,
    "verse": 21,
    "text": "Blessed be the LORD out of Zion, which dwelleth at Jerusalem. Praise ye the LORD.",
    "hash": "f63a8be19410a924a3e0a892ac30fcb9cfbfd99a9c2a5c182fdce50a56de740d"
  }
]