[
  {
    "id": "PSA.132.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 1,
    "text": "A Song of degrees. LORD, remember David, {and} all his afflictions:",
    "hash": "19b7b497acd896b23ef323dfa88906869e023694361e06557df45d5e7363ae94"
  },
  {
    "id": "PSA.132.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 2,
    "text": "How he sware unto the LORD, {and} vowed unto the mighty {God} of Jacob;",
    "hash": "71e8265ff606dc5926c9a9c1105db744fe5dba41afdccc01f55506550e4ffe7e"
  },
  {
    "id": "PSA.132.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 3,
    "text": "Surely I will not come into the tabernacle of my house, nor go up into my bed;",
    "hash": "2a1c0dc63f88214ceb4113139b0eba505ace75b83ef7458f65961754e95ea9a4"
  },
  {
    "id": "PSA.132.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 4,
    "text": "I will not give sleep to mine eyes, {or} slumber to mine eyelids,",
    "hash": "28a4c0240e91e1cec64c2b203a996a630b1d87d1f1eaa1e2cf5643a89242ba1c"
  },
  {
    "id": "PSA.132.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 5,
    "text": "Until I find out a place for the LORD, an habitation for the mighty {God} of Jacob. {an habitation: Heb. habitations}",
    "hash": "66939d9c5316da529d9153240f03e6d6084361157107ecbb0eb79d5f76b2d5a8"
  },
  {
    "id": "PSA.132.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 6,
    "text": "Lo, we heard of it at Ephratah: we found it in the fields of the wood.",
    "hash": "fdb07f171a60935845d9d8359d024ee42987d0c0d97b99427ad73609879d05be"
  },
  {
    "id": "PSA.132.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 7,
    "text": "We will go into his tabernacles: we will worship at his footstool.",
    "hash": "73a21bb8d701c8a05dd906f7db0b7609816f49b7bf7e70ef261cc5ec9931fdd3"
  },
  {
    "id": "PSA.132.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 8,
    "text": "Arise, O LORD, into thy rest; thou, and the ark of thy strength.",
    "hash": "47a6447f138efc955b2ef3eef73fca4a9e2c8e0576157d55ebe436e9474e3909"
  },
  {
    "id": "PSA.132.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 9,
    "text": "Let thy priests be clothed with righteousness; and let thy saints shout for joy.",
    "hash": "1b5ae3aa0cda5cc10e449c24b3e55936e44b67526e303a35117e70c1b80cc173"
  },
  {
    "id": "PSA.132.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 10,
    "text": "For thy servant David's sake turn not away the face of thine anointed.",
    "hash": "0dd2d5471c8895dd3ab44c3552cd48472fe2dc830aa132a2e6fc3de10a0ee073"
  },
  {
    "id": "PSA.132.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 11,
    "text": "The LORD hath sworn {in} truth unto David; he will not turn from it; Of the fruit of thy body will I set upon thy throne. {body: Heb. belly}",
    "hash": "8c3a821cd5a0d060a54ff86e8ac1ef03ed1ac3dccbb1791864fcfb2c99932061"
  },
  {
    "id": "PSA.132.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 12,
    "text": "If thy children will keep my covenant and my testimony that I shall teach them, their children shall also sit upon thy throne for evermore.",
    "hash": "4cb94f6c32a1522bbb7090b98d7bd37338812de680ac02063ec79e8f32480bbf"
  },
  {
    "id": "PSA.132.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 13,
    "text": "For the LORD hath chosen Zion; he hath desired {it} for his habitation.",
    "hash": "5bd92520e50816fba42edc0bc5ccf32446397e10ea5774c9ce139c2c28854572"
  },
  {
    "id": "PSA.132.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 14,
    "text": "This {is} my rest for ever: here will I dwell; for I have desired it.",
    "hash": "3430cb0c575d100195986ed8a9d2615d22e0b7910b08aa043cba343d3531b0ea"
  },
  {
    "id": "PSA.132.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 15,
    "text": "I will abundantly bless her provision: I will satisfy her poor with bread. {abundantly: or, surely}",
    "hash": "c2ca54322ae500663303c4f074fcbdca58d84290cf18ba5858e83422cbc61b43"
  },
  {
    "id": "PSA.132.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 16,
    "text": "I will also clothe her priests with salvation: and her saints shall shout aloud for joy.",
    "hash": "21a1d03241b6b75257089aa71c3efee966be95b8fa6a5c5ed01450da115b8ea3"
  },
  {
    "id": "PSA.132.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 17,
    "text": "There will I make the horn of David to bud: I have ordained a lamp for mine anointed. {lamp: or, candle}",
    "hash": "f70d8b78874a934ffe7149101795449118e55438b9ab03d791ef925833a9b6c7"
  },
  {
    "id": "PSA.132.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 132,
    "verse": 18,
    "text": "His enemies will I clothe with shame: but upon himself shall his crown flourish.",
    "hash": "bf3d6c06bb2daa54d5c403768c9394e31e1603db1a05b7d1e97ed0f221ef03d2"
  }
]