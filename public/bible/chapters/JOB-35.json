  },
  {
    "id": "JOB.35.2",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 2,
    "text": "Thinkest thou this to be right, {that} thou saidst, My righteousness {is} more than God's?",
    "hash": "c7b96dd3a3024c42b8bbe9170e5681c927c90e1a1f6d1c5d6f168e4d2f3e7a34"
  },
  {
    "id": "JOB.35.3",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 3,
    "text": "For thou saidst, What advantage will it be unto thee? {and}, What profit shall I have, {if I be cleansed} from my sin? {if...: or, by it more than by my sin}",
