  },
  {
    "id": "JOB.35.4",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 4,
    "text": "I will answer thee, and thy companions with thee. {answer...: Heb. return to thee words}",
