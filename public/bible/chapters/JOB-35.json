  },
  {
    "id": "JOB.35.5",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 5,
    "text": "Look unto the heavens, and see; and behold the clouds {which} are higher than thou.",
    "hash": "3e7795f3e5aa35d1e33d853211490a7e0a2b65177b947ea2aaea73cb9017bd40"
  },
  {
    "id": "JOB.35.6",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 6,
    "text": "If thou sinnest, what doest thou against him? or {if} thy transgressions be multiplied, what doest thou unto him?",
    "hash": "0e19502064adcc8ecc985f29691dd4a36d8971ee8b8e52ece77259e7ea912b45"
  },
  {
    "id": "JOB.35.7",
    "book": "Job",
    "bookNum": 18,
    "bookAbbrev": "JOB",
    "chapter": 35,
    "verse": 7,
    "text": "If thou be righteous, what givest thou him? or what receiveth he of thine hand?",
