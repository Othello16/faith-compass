[
  {
    "id": "PSA.48.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 1,
    "text": "[A Song {and} Psalm for the sons of Korah.] Great {is} the LORD, and greatly to be praised in the city of our God, {in} the mountain of his holiness. {for: or, of}",
    "hash": "d325bb3bc652491048d21247e6377c8a585e286c2cbb964165b9a9dcb79cbb22"
  },
  {
    "id": "PSA.48.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 2,
    "text": "Beautiful for situation, the joy of the whole earth, {is} mount Zion, {on} the sides of the north, the city of the great King.",
    "hash": "075b775d40febae3e98c74e321b39e054e4ec31a32c7db9f046cc7f170840268"
  },
  {
    "id": "PSA.48.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 3,
    "text": "God is known in her palaces for a refuge.",
    "hash": "948b38e0683ed590654d0b25e4d9d63ba99b920cfafb8aba5744499651669ffa"
  },
  {
    "id": "PSA.48.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 4,
    "text": "For, lo, the kings were assembled, they passed by together.",
    "hash": "9505deab4998f68c7693594627f2b9787c638f37045b359806eb882c73791259"
  },
  {
    "id": "PSA.48.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 5,
    "text": "They saw {it, and} so they marvelled; they were troubled, {and} hasted away.",
    "hash": "a2dd33eb6667560544d32fbd68df756e3b29d52166ed6bf2fa864c39c0631fd2"
  },
  {
    "id": "PSA.48.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 6,
    "text": "Fear took hold upon them there, {and} pain, as of a woman in travail.",
    "hash": "36d121c2b972d2daab68fc4e1b2f7f19736654d188735ee467644a207a11f397"
  },
  {
    "id": "PSA.48.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 7,
    "text": "Thou breakest the ships of Tarshish with an east wind.",
    "hash": "2f3db43c90e0af77b0fc4f2f07ee36d9979fb5fb773f1ad848f86a1bf4c5ff11"
  },
  {
    "id": "PSA.48.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 8,
    "text": "As we have heard, so have we seen in the city of the LORD of hosts, in the city of our God: God will establish it for ever. Selah.",
    "hash": "b84c2a7e49f7430f0886f727bd15372c8ebcb9cb30d467cf71164433949f6554"
  },
  {
    "id": "PSA.48.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 9,
    "text": "We have thought of thy lovingkindness, O God, in the midst of thy temple.",
    "hash": "87a26d692ed75a4d0274b4ab20cee5ff6a5eb12c3bb70abb8e3d7a877afef554"
  },
  {
    "id": "PSA.48.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 10,
    "text": "According to thy name, O God, so {is} thy praise unto the ends of the earth: thy right hand is full of righteousness.",
    "hash": "c1ba73a6c016e430314294b8010dc10e5c7584a308a26137599330d1520c26f5"
  },
  {
    "id": "PSA.48.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 11,
    "text": "Let mount Zion rejoice, let the daughters of Judah be glad, because of thy judgments.",
    "hash": "82e1e24d69b798d741f45f772dbea15bfe9302223ef39dcc5c4f1ffb3f62fa16"
  },
  {
    "id": "PSA.48.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 12,
    "text": "Walk about Zion, and go round about her: tell the towers thereof.",
    "hash": "8e7422f33e712de21744ce5b076ec4384b05cab345777f1b01a3a1598aeb90d0"
  },
  {
    "id": "PSA.48.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 13,
    "text": "Mark ye well her bulwarks, consider her palaces; that ye may tell {it} to the generation following. {Mark...: Heb. Set your heart to} {consider: or, raise up}",
    "hash": "b562c604d45f1ab7300cd49df8a58c35140e1dba1495e9d152bf75bf95526e62"
  },
  {
    "id": "PSA.48.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 48,
    "verse": 14,
    "text": "For this God {is} our God for ever and ever: he will be our guide {even} unto death.",
    "hash": "f4ab17f5f08777909325156bc64368815440994bde34cc5c0e10c5d7093e8f47"
  }
]