[
  {
    "id": "PSA.116.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 1,
    "text": "I love the LORD, because he hath heard my voice {and} my supplications.",
    "hash": "8d8fce1b504b7a96f436f80c9a13068ead108220e6284b892f695383a328135e"
  },
  {
    "id": "PSA.116.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 2,
    "text": "Because he hath inclined his ear unto me, therefore will I call upon {him} as long as I live. {as long...: Heb. in my days}",
    "hash": "630b81c6a57c5ec7dfcb2cab26fe512f1364e83ce0d32467af86fd3aac762e19"
  },
  {
    "id": "PSA.116.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 3,
    "text": "The sorrows of death compassed me, and the pains of hell gat hold upon me: I found trouble and sorrow. {gat...: Heb. found me}",
    "hash": "30af1a64c129c3e4071326e1f32d4c3a7e08f8174f711efb1825d89285387e88"
  },
  {
    "id": "PSA.116.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 4,
    "text": "Then called I upon the name of the LORD; O LORD, I beseech thee, deliver my soul.",
    "hash": "b8c035ee2038464db2c95d5d9ae01e2f89990d57cc1dbb8bea35653f066cc76a"
  },
  {
    "id": "PSA.116.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 5,
    "text": "Gracious {is} the LORD, and righteous; yea, our God {is} merciful.",
    "hash": "54e2867de3da458dbf455f749a5de0224e6b99d4d4eaf5efde0fdad9ca5be368"
  },
  {
    "id": "PSA.116.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 6,
    "text": "The LORD preserveth the simple: I was brought low, and he helped me.",
    "hash": "b59afdfe169b10907f8b603d91acacf35a0be05bb0c5f5ed64e296b6113f4aca"
  },
  {
    "id": "PSA.116.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 7,
    "text": "Return unto thy rest, O my soul; for the LORD hath dealt bountifully with thee.",
    "hash": "a2b42e9f385832ff1cd17fc0cfed47417a928d029e2c307f400d84a11781e8bc"
  },
  {
    "id": "PSA.116.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 8,
    "text": "For thou hast delivered my soul from death, mine eyes from tears, {and} my feet from falling.",
    "hash": "83d2b51feb5c12847740ce675f80b2afa9a4f8e1735e6e78b6df6c113f83705f"
  },
  {
    "id": "PSA.116.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 9,
    "text": "I will walk before the LORD in the land of the living.",
    "hash": "9362c68b3f574c62ea5e18d103a3136efbd4fe0a96f9e34f60672dbd9d105c03"
  },
  {
    "id": "PSA.116.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 10,
    "text": "I believed, therefore have I spoken: I was greatly afflicted:",
    "hash": "e695f1649b108e0df2a8f00c0d41765f03b6d028142abe7c6f894873652c0564"
  },
  {
    "id": "PSA.116.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 11,
    "text": "I said in my haste, All men {are} liars.",
    "hash": "d6385524f7344c4417e64a2746fbd65e57a12955ab1b29bf3dfb6ce411ed11cb"
  },
  {
    "id": "PSA.116.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 12,
    "text": "What shall I render unto the LORD {for} all his benefits toward me?",
    "hash": "502504354850e390ca704b011384cd7cdc96f30f57ae808082ab9bcd44c75d2d"
  },
  {
    "id": "PSA.116.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 13,
    "text": "I will take the cup of salvation, and call upon the name of the LORD.",
    "hash": "3c29a5f065d7aa18412dad0088f75c192aee768d54f193cb28875dc41fee5cc6"
  },
  {
    "id": "PSA.116.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 14,
    "text": "I will pay my vows unto the LORD now in the presence of all his people.",
    "hash": "75b6d7641db05bbeb155bec942e6ee0f721182af6ebbbbc10f8c8040051c2961"
  },
  {
    "id": "PSA.116.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 15,
    "text": "Precious in the sight of the LORD {is} the death of his saints.",
    "hash": "08466b9f2b67062681cbda7649db0d590c136bf7307271b28bc7e7189765d4f8"
  },
  {
    "id": "PSA.116.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 16,
    "text": "O LORD, truly I {am} thy servant; I {am} thy servant, {and} the son of thine handmaid: thou hast loosed my bonds.",
    "hash": "40d5d51aaf9fb03fc53a9a584f5420f4b2684332469ffede36aa36053bd9a183"
  },
  {
    "id": "PSA.116.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 17,
    "text": "I will offer to thee the sacrifice of thanksgiving, and will call upon the name of the LORD.",
    "hash": "1bb7a68c36f7ea1290d2782b1931622c258c9e768524baa5fd0a326c1282dba4"
  },
  {
    "id": "PSA.116.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 18,
    "text": "I will pay my vows unto the LORD now in the presence of all his people,",
    "hash": "60e2eedc65e34fe2f131b39d8e1c1fafa152d38173bc93b9c030601ec473ba88"
  },
  {
    "id": "PSA.116.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 116,
    "verse": 19,
    "text": "In the courts of the LORD'S house, in the midst of thee, O Jerusalem. Praise ye the LORD.",
    "hash": "463a68484ee33408bb9088ec3bcef2d5dd7a6627ffc291e18b80f8c1379be325"
  }
]