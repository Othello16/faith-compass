[
  {
    "id": "PSA.145.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 1,
    "text": "[David's {Psalm} of praise.] I will extol thee, my God, O king; and I will bless thy name for ever and ever.",
    "hash": "7c10463b7ca1288e79c330b71d313c9860b7ede1e822d3917187eea234054e03"
  },
  {
    "id": "PSA.145.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 2,
    "text": "Every day will I bless thee; and I will praise thy name for ever and ever.",
    "hash": "94e0a4e76f9411a76dc01d4bf4b08e4369d09df51ee71a5012847102833e3797"
  },
  {
    "id": "PSA.145.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 3,
    "text": "Great {is} the LORD, and greatly to be praised; and his greatness {is} unsearchable. {and his...: Heb. and of his greatness there is no search}",
    "hash": "8da9aae5f129d9cdb7ebd0faeee9e53629578cd8a4dd7c966c9f54580b883cfb"
  },
  {
    "id": "PSA.145.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 4,
    "text": "One generation shall praise thy works to another, and shall declare thy mighty acts.",
    "hash": "60f15207667810737af39b36e221802978de843ca5297e93288f496647992a06"
  },
  {
    "id": "PSA.145.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 5,
    "text": "I will speak of the glorious honour of thy majesty, and of thy wondrous works. {works: Heb. things, or, words}",
    "hash": "9dd2ccc61acdead0d5839542c421a21399277c3ded62d69e77077364734a07fc"
  },
  {
    "id": "PSA.145.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 6,
    "text": "And {men} shall speak of the might of thy terrible acts: and I will declare thy greatness. {declare: Heb. declare it}",
    "hash": "f9a58c9bb9892d7431c966ab56217974bdb1e151906ae1abeb660d5b5022aa1c"
  },
  {
    "id": "PSA.145.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 7,
    "text": "They shall abundantly utter the memory of thy great goodness, and shall sing of thy righteousness.",
    "hash": "42c062fe67e38f32bcf01ca5d400062fcc76a4edbe94a3a12eef482de08ea162"
  },
  {
    "id": "PSA.145.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 8,
    "text": "The LORD {is} gracious, and full of compassion; slow to anger, and of great mercy. {of great...: Heb. great in mercy}",
    "hash": "f5753ad34136ba36542a4851b5a313933bf4eb34f3e11db9e8bc243020bf8143"
  },
  {
    "id": "PSA.145.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 9,
    "text": "The LORD {is} good to all: and his tender mercies {are} over all his works.",
    "hash": "8b4f5b412414cfeccf21726523a6bc482d640d97fa6e673159c6231fc766dc61"
  },
  {
    "id": "PSA.145.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 10,
    "text": "All thy works shall praise thee, O LORD; and thy saints shall bless thee.",
    "hash": "ea32ab8a13cfaca60f3e76eea787fd211cb98ccfe1d093a60bf0c1b99785f090"
  },
  {
    "id": "PSA.145.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 11,
    "text": "They shall speak of the glory of thy kingdom, and talk of thy power;",
    "hash": "713b30294c5cac81b2f4da172ce5778378bdf4406ad6113437bd734932f4dea8"
  },
  {
    "id": "PSA.145.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 12,
    "text": "To make known to the sons of men his mighty acts, and the glorious majesty of his kingdom.",
    "hash": "552ede14d2f41bcf19d79399c269ece52ef03ddc3c6a93fcc23a2cbabafc3d30"
  },
  {
    "id": "PSA.145.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 13,
    "text": "Thy kingdom {is} an everlasting kingdom, and thy dominion {endureth} throughout all generations. {an...: Heb. a kingdom of all ages}",
    "hash": "8b0777335d1a1f76ae4ff5d1dd02a3ef8c073f003d63d1e49fcb51cd0da866c5"
  },
  {
    "id": "PSA.145.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 14,
    "text": "The LORD upholdeth all that fall, and raiseth up all {those that be} bowed down.",
    "hash": "94beab3fc504ea0ce462da87eda06850e40e98b8d3d6280f16c39fbed09026d7"
  },
  {
    "id": "PSA.145.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 15,
    "text": "The eyes of all wait upon thee; and thou givest them their meat in due season. {wait...: or, look unto}",
    "hash": "ee5ea5dc29851a66b9098bde1eca3210903033eccf36e249884afbd42d28f34b"
  },
  {
    "id": "PSA.145.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 16,
    "text": "Thou openest thine hand, and satisfiest the desire of every living thing.",
    "hash": "cd7b0afaa98a8a42d554efc11c888779079d1b0d3ca892628eb9afa91a5f9a2b"
  },
  {
    "id": "PSA.145.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 17,
    "text": "The LORD {is} righteous in all his ways, and holy in all his works. {holy: or, merciful, or, bountiful}",
    "hash": "59995b84711fc6b3b473279e72314491507a009ccc3ce20ccbdf5e7f550aa649"
  },
  {
    "id": "PSA.145.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 18,
    "text": "The LORD {is} nigh unto all them that call upon him, to all that call upon him in truth.",
    "hash": "499c21dbf153c06428f89a24b365be979f14bb5b56e5e6a885fb4f0be1d5985c"
  },
  {
    "id": "PSA.145.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 19,
    "text": "He will fulfil the desire of them that fear him: he also will hear their cry, and will save them.",
    "hash": "928917264135b51fed040fb9b8dcb630c95a2b7c35bdee0d91f49882e6139704"
  },
  {
    "id": "PSA.145.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 20,
    "text": "The LORD preserveth all them that love him: but all the wicked will he destroy.",
    "hash": "8f47b57fb20f035c7efdd175cb0b7111c50053c47466501f30e66c26b53463d5"
  },
  {
    "id": "PSA.145.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 145,
    "verse": 21,
    "text": "My mouth shall speak the praise of the LORD: and let all flesh bless his holy name for ever and ever.",
    "hash": "53e0e65e5add32189954a137acc73be0a40ef2c043415c69e7034799e298de36"
  }
]