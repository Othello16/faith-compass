[
  {
    "id": "PSA.108.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 1,
    "text": "[A Song {or} Psalm of David.] O God, my heart is fixed; I will sing and give praise, even with my glory.",
    "hash": "d23257e563359c4a2686b8b1cc8e5d6aa7d359b23c74ace7de43d6d722fd1552"
  },
  {
    "id": "PSA.108.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 2,
    "text": "Awake, psaltery and harp: I {myself} will awake early.",
    "hash": "385ed454d10cefa4d2da12c7c5b3e4ff131f697f222363abc52dda0c780f8f7d"
  },
  {
    "id": "PSA.108.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 3,
    "text": "I will praise thee, O LORD, among the people: and I will sing praises unto thee among the nations.",
    "hash": "bfc85db6e91e5c2b75f26b4dbf5505cd715a7f4f73d723afabb2daefe362f82a"
  },
  {
    "id": "PSA.108.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 4,
    "text": "For thy mercy {is} great above the heavens: and thy truth {reacheth} unto the clouds. {clouds: or, skies}",
    "hash": "af66f6baccda946b67570fa925cb5f8420d178371ec40b31ec0265c3ded914be"
  },
  {
    "id": "PSA.108.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 5,
    "text": "Be thou exalted, O God, above the heavens: and thy glory above all the earth;",
    "hash": "5d977a8247c6273c9fcaa4f7bda00aa80f52b526a2d5b75d2232173d48ee3272"
  },
  {
    "id": "PSA.108.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 6,
    "text": "That thy beloved may be delivered: save {with} thy right hand, and answer me.",
    "hash": "4467d85e22e494644e6e22383e9b378f15d3630b6df45cc6a4182a1342b97150"
  },
  {
    "id": "PSA.108.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 7,
    "text": "God hath spoken in his holiness; I will rejoice, I will divide Shechem, and mete out the valley of Succoth.",
    "hash": "879e0b2dd4e3331d6058b038a4cd25ab0a37353dd1a81d9462bb9c6cabadbb82"
  },
  {
    "id": "PSA.108.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 8,
    "text": "Gilead {is} mine; Manasseh {is} mine; Ephraim also {is} the strength of mine head; Judah {is} my lawgiver;",
    "hash": "8d83aaf15557d4aa6207e071ddf01feed5dbbbbf30bac94cb0793810c21d9930"
  },
  {
    "id": "PSA.108.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 9,
    "text": "Moab {is} my washpot; over Edom will I cast out my shoe; over Philistia will I triumph.",
    "hash": "c750d8ceacfb33f435b43217b2f27dce253a2ef94d4b174191664b1472b49857"
  },
  {
    "id": "PSA.108.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 10,
    "text": "Who will bring me into the strong city? who will lead me into Edom?",
    "hash": "addd99e8f6a9cb6d995a33483ec2c8fa4276cd05c2fe4f7c825cf5b9bb2b8eb3"
  },
  {
    "id": "PSA.108.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 11,
    "text": "{Wilt} not {thou}, O God, {who} hast cast us off? and wilt not thou, O God, go forth with our hosts?",
    "hash": "c383a8f0052625d144f800f841e45c4f06eff4671027458395c65508bf34d1b2"
  },
  {
    "id": "PSA.108.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 12,
    "text": "Give us help from trouble: for vain {is} the help of man.",
    "hash": "57b1245ff335b578e4807e7d7b68602d7fc5bfecb0381d2f55615690a292b4f4"
  },
  {
    "id": "PSA.108.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 108,
    "verse": 13,
    "text": "Through God we shall do valiantly: for he {it is that} shall tread down our enemies.",
    "hash": "ec840b2423d8014c5cab4fe4e7aa42d193d2977dd2e600487f3db5eab6596122"
  }
]