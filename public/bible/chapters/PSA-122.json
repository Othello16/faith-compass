[
  {
    "id": "PSA.122.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 1,
    "text": "[A Song of degrees of David.] I was glad when they said unto me, Let us go into the house of the LORD.",
    "hash": "a1c5a441d50fdefaa35651038b46a89ad0027b2858035a4e4b42309cf43a6d4a"
  },
  {
    "id": "PSA.122.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 2,
    "text": "Our feet shall stand within thy gates, O Jerusalem.",
    "hash": "0af1e5c074ecdf4732a4f92e506545b52f48373b422924cc1d90f53e535987f9"
  },
  {
    "id": "PSA.122.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 3,
    "text": "Jerusalem is builded as a city that is compact together:",
    "hash": "3ab319051eabf87f0bffebf8a0ebb32d997b830b6d5d655d20dd8021e683a75b"
  },
  {
    "id": "PSA.122.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 4,
    "text": "Whither the tribes go up, the tribes of the LORD, unto the testimony of Israel, to give thanks unto the name of the LORD.",
    "hash": "e3c75fcbe93177a8268e3549056d75dff79605f28dfcb71a64b85592a4f7b94d"
  },
  {
    "id": "PSA.122.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 5,
    "text": "For there are set thrones of judgment, the thrones of the house of David. {are...: Heb. do sit}",
    "hash": "fbb431f8d416511960b73d1dc6f49539cf1f9fece00df6e8341c2b92ad8d22df"
  },
  {
    "id": "PSA.122.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 6,
    "text": "Pray for the peace of Jerusalem: they shall prosper that love thee.",
    "hash": "b589a9c5101689d4d22ceff614925096fd2f78f74c3fad045c621bb4cdb6beef"
  },
  {
    "id": "PSA.122.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 7,
    "text": "Peace be within thy walls, {and} prosperity within thy palaces.",
    "hash": "4e35e1ba75e0eddb8430a05c7f280d54466a11355c705947de63fa5a1a1e5149"
  },
  {
    "id": "PSA.122.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 8,
    "text": "For my brethren and companions' sakes, I will now say, Peace {be} within thee.",
    "hash": "aba7ae010070a478e9903e4f87c41719a9bea2523b6de4b9306f5d3daf9836a7"
  },
  {
    "id": "PSA.122.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 122,
    "verse": 9,
    "text": "Because of the house of the LORD our God I will seek thy good.",
    "hash": "6af2aabcc5d5b86ddd1d9b796cf32398d156951dd5b883949a02ab26c9f416b8"
  }
]