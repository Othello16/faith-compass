[
  {
    "id": "PSA.148.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 1,
    "text": "Praise ye the LORD. Praise ye the LORD from the heavens: praise him in the heights. {Praise ye the LORD. Praise: Heb. Hallelujah, etc}",
    "hash": "d89c2d05bf12f000777f644567876d6075e38f3e266e2a498de04fa40b606e5b"
  },
  {
    "id": "PSA.148.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 2,
    "text": "Praise ye him, all his angels: praise ye him, all his hosts.",
    "hash": "0b0345a59cc29dd3be639b4718b28989b7b4213e796ebb1a69ca89b9c136a359"
  },
  {
    "id": "PSA.148.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 3,
    "text": "Praise ye him, sun and moon: praise him, all ye stars of light.",
    "hash": "d186446e31e633c168f1b5866217b18d4ed80da5d862f1f9162fe8d6ca9f545f"
  },
  {
    "id": "PSA.148.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 4,
    "text": "Praise him, ye heavens of heavens, and ye waters that {be} above the heavens.",
    "hash": "46c42ee400d6741f8c55a89e223f941de2f336a62b0f6540e4bc2191e7ac6a49"
  },
  {
    "id": "PSA.148.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 5,
    "text": "Let them praise the name of the LORD: for he commanded, and they were created.",
    "hash": "322fbdeb98cb7dc4f0f1dbf84c16997c15e5fb62ff3c4d2201fa3e5d613248b3"
  },
  {
    "id": "PSA.148.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 6,
    "text": "He hath also stablished them for ever and ever: he hath made a decree which shall not pass.",
    "hash": "85dc167fd664c317608f2aea89f4b9858cc1ef87e4ed2cac55759b8e76ccbce9"
  },
  {
    "id": "PSA.148.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 7,
    "text": "Praise the LORD from the earth, ye dragons, and all deeps:",
    "hash": "c9131da8c42eaec0f66d2167e9a7bb170599e6b3abecd0dc44a203317eb14058"
  },
  {
    "id": "PSA.148.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 8,
    "text": "Fire, and hail; snow, and vapour; stormy wind fulfilling his word:",
    "hash": "62d4b030485de9224a957aad1105a606bd4190f067ae2349d9076426162b51b3"
  },
  {
    "id": "PSA.148.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 9,
    "text": "Mountains, and all hills; fruitful trees, and all cedars:",
    "hash": "57d3ea6738f0c558bef1b1e2671038ee6a88b77eb066c1ea18288a0b2c8c9b01"
  },
  {
    "id": "PSA.148.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 10,
    "text": "Beasts, and all cattle; creeping things, and flying fowl: {flying...: Heb. birds of wing}",
    "hash": "119932639f2830159c071c6403fbe4365381da9c9dfa0d072b3f8c7a96420a46"
  },
  {
    "id": "PSA.148.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 11,
    "text": "Kings of the earth, and all people; princes, and all judges of the earth:",
    "hash": "498e04baf95cc2c44b2aff3f0e20b264d78fb4fa6083a55c85c72b1c4e4d9d7b"
  },
  {
    "id": "PSA.148.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 12,
    "text": "Both young men, and maidens; old men, and children:",
    "hash": "cec26076ec1bd8f3b170b7a5d67e9aff1a19c73199879d9b673a345b19f6b764"
  },
  {
    "id": "PSA.148.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 13,
    "text": "Let them praise the name of the LORD: for his name alone is excellent; his glory {is} above the earth and heaven. {excellent: Heb. exalted}",
    "hash": "86f3d894eddd4330c136cffbd213f2116e7edbe9d87c5f549ae4a41e59033a05"
  },
  {
    "id": "PSA.148.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 148,
    "verse": 14,
    "text": "He also exalteth the horn of his people, the praise of all his saints; {even} of the children of Israel, a people near unto him. Praise ye the LORD.",
    "hash": "ae7a15013c7203ba503dde2e022f06cdd02bc6f66eb79458bd8d37fa7c86321d"
  }
]