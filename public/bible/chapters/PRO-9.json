[
  {
    "id": "PRO.9.1",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 1,
    "text": "Wisdom hath builded her house, she hath hewn out her seven pillars:",
    "hash": "482d37d2315101fde298a7bd1ffaf38e18176365bb4239e227888ce52cdd10ab"
  },
  {
    "id": "PRO.9.2",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 2,
    "text": "She hath killed her beasts; she hath mingled her wine; she hath also furnished her table. {her beasts: Heb. her killing}",
    "hash": "2d63532c0ad9844f71d3f7bca12a823d3524af5360ed1c2a2632dfbeecc06f33"
  },
  {
    "id": "PRO.9.3",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 3,
    "text": "She hath sent forth her maidens: she crieth upon the highest places of the city,",
    "hash": "8c8079c87ef42412002d0c185d200b02d3a4bb9894df346446052e0151f46246"
  },
  {
    "id": "PRO.9.4",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 4,
    "text": "Whoso {is} simple, let him turn in hither: {as for} him that wanteth understanding, she saith to him,",
    "hash": "aaafab1518297ed49c60deeb3f540c4646acfea4665a232339cc51fa03fdcb5f"
  },
  {
    "id": "PRO.9.5",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 5,
    "text": "Come, eat of my bread, and drink of the wine {which} I have mingled.",
    "hash": "e2a66cde1877f74eccc1e11ad6c033a4c8d8dcbf7bd6b3c799797d4d9518373f"
  },
  {
    "id": "PRO.9.6",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 6,
    "text": "Forsake the foolish, and live; and go in the way of understanding.",
    "hash": "9e63ac718750f663a955bcf7c7f0655cda88351746fbf6d728b9cdf55a8fd242"
  },
  {
    "id": "PRO.9.7",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 7,
    "text": "He that reproveth a scorner getteth to himself shame: and he that rebuketh a wicked {man getteth} himself a blot.",
    "hash": "ccf1f77dfefa9e777fde1a6a6cc127099ce14c6e7005dcc31017495e5b37bea4"
  },
  {
    "id": "PRO.9.8",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 8,
    "text": "Reprove not a scorner, lest he hate thee: rebuke a wise man, and he will love thee.",
    "hash": "7504ec7776dfb7acc5e02ad10098ee1480d2a961648ac324638fca75fff3c144"
  },
  {
    "id": "PRO.9.9",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 9,
    "text": "Give {instruction} to a wise {man}, and he will be yet wiser: teach a just {man}, and he will increase in learning.",
    "hash": "afb22bafb4e595c4e1d30fe758432db51b0c71921ef5acd7dee801147b4e683b"
  },
  {
    "id": "PRO.9.10",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 10,
    "text": "The fear of the LORD {is} the beginning of wisdom: and the knowledge of the holy {is} understanding.",
    "hash": "7f8259feaa88cfd92199884ee6110af8d11de001071164c158447fa6dee391ff"
  },
  {
    "id": "PRO.9.11",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 11,
    "text": "For by me thy days shall be multiplied, and the years of thy life shall be increased.",
    "hash": "57c3baf38b738d0fbe8616138c093dcef6bb16101be9547c5595758f79b1aad4"
  },
  {
    "id": "PRO.9.12",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 12,
    "text": "If thou be wise, thou shalt be wise for thyself: but {if} thou scornest, thou alone shalt bear {it}.",
    "hash": "f3db8ece08111061a2ab79c768118f64b454764e9bfec3affa7030ffe599450f"
  },
  {
    "id": "PRO.9.13",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 13,
    "text": "A foolish woman {is} clamorous: {she is} simple, and knoweth nothing.",
    "hash": "f52c1cb0ff4514adac003290d680b73ad0c80bcc3ba0fd470296aa9a21572a02"
  },
  {
    "id": "PRO.9.14",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 14,
    "text": "For she sitteth at the door of her house, on a seat in the high places of the city,",
    "hash": "453389efde88cf192333c9a152bcd4c89ddde433b83606bedbb03caaca634a3b"
  },
  {
    "id": "PRO.9.15",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 15,
    "text": "To call passengers who go right on their ways:",
    "hash": "4958e6eb25898e795640bd1a49b30c321fd0c13298fc3a5efd670a3122f58a99"
  },
  {
    "id": "PRO.9.16",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 16,
    "text": "Whoso {is} simple, let him turn in hither: and {as for} him that wanteth understanding, she saith to him,",
    "hash": "0afa0645d0a3ae77f2d11880f7b0a77692cfed0b7616bc897d5ed36c22ddba83"
  },
  {
    "id": "PRO.9.17",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 17,
    "text": "Stolen waters are sweet, and bread {eaten} in secret is pleasant. {eaten...: Heb. of secrecies}",
    "hash": "2e10fd2391f20ce72d0a290bcfa3b858c8e07568e9ea4a63ee95ff7a2f5fdaa9"
  },
  {
    "id": "PRO.9.18",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 9,
    "verse": 18,
    "text": "But he knoweth not that the dead {are} there; {and that} her guests {are} in the depths of hell.",
    "hash": "67b3263e22f53ad7c40bc22f29e9b4253b16159cfb95d9fbbee63c8b0b4cfe7c"
  }
]