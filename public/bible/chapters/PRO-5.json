[
  {
    "id": "PRO.5.1",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 1,
    "text": "My son, attend unto my wisdom, {and} bow thine ear to my understanding:",
    "hash": "57fa7c92875554c66e03bb59f968054eedb9b962a683c6a1f48f61afbd80349e"
  },
  {
    "id": "PRO.5.2",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 2,
    "text": "That thou mayest regard discretion, and {that} thy lips may keep knowledge.",
    "hash": "08ba640512359065b4b344b6eec5911af0f119889327abcd3634d3e06dbfdf1c"
  },
  {
    "id": "PRO.5.3",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 3,
    "text": "For the lips of a strange woman drop {as} an honeycomb, and her mouth {is} smoother than oil: {mouth: Heb. palate}",
    "hash": "6384b4974effa097ad9cfd2676ec0294297544d3019dbc95f9952ae47b60e7ed"
  },
  {
    "id": "PRO.5.4",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 4,
    "text": "But her end is bitter as wormwood, sharp as a twoedged sword.",
    "hash": "52e56ddb18f98f3c402b719de76eb0bcd3ff2a53e97b807c609eb3bfbc2582e1"
  },
  {
    "id": "PRO.5.5",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 5,
    "text": "Her feet go down to death; her steps take hold on hell.",
    "hash": "ea368e3cf324c86c8db98853aa9b51091b7110527522a24a695a1a3c50de54b5"
  },
  {
    "id": "PRO.5.6",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 6,
    "text": "Lest thou shouldest ponder the path of life, her ways are moveable, {that} thou canst not know {them}.",
    "hash": "e2d70dc51a71fb91b7fb3e44eb940821a1e9961ca5b834bc2d54244b60ec21e0"
  },
  {
    "id": "PRO.5.7",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 7,
    "text": "Hear me now therefore, O ye children, and depart not from the words of my mouth.",
    "hash": "de3da8fa28c0ad2aa5c61a19000ee176ee4e313b43b3be93597aa6b5e8cf21f6"
  },
  {
    "id": "PRO.5.8",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 8,
    "text": "Remove thy way far from her, and come not nigh the door of her house:",
    "hash": "d5c2360d8ab8c3fab376a41ccdd9a2078823200d93f483617b226ea8f4e7af2e"
  },
  {
    "id": "PRO.5.9",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 9,
    "text": "Lest thou give thine honour unto others, and thy years unto the cruel:",
    "hash": "4f931f74ac3a79a79fa47243e9d8dfbe32c2c2aea50ee2143f23db96244e43b0"
  },
  {
    "id": "PRO.5.10",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 10,
    "text": "Lest strangers be filled with thy wealth; and thy labours {be} in the house of a stranger; {thy wealth: Heb. thy strength}",
    "hash": "59af828ce85e75816bea7fa2a38fcab6ec79904289b332751889202e78d4834c"
  },
  {
    "id": "PRO.5.11",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 11,
    "text": "And thou mourn at the last, when thy flesh and thy body are consumed,",
    "hash": "b69fcda6581d6af228d2580d796db64d72cde10ab7a9f829a2bde4a591c59cd9"
  },
  {
    "id": "PRO.5.12",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 12,
    "text": "And say, How have I hated instruction, and my heart despised reproof;",
    "hash": "1ea598f648fd5c4565571193e37ce4c1e19fda7cb49b6c303069090c1d6ce213"
  },
  {
    "id": "PRO.5.13",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 13,
    "text": "And have not obeyed the voice of my teachers, nor inclined mine ear to them that instructed me!",
    "hash": "f23e4a389ff6e7fd6eb32190fed3b832f280d60c17582082f627668d00dae6d8"
  },
  {
    "id": "PRO.5.14",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 14,
    "text": "I was almost in all evil in the midst of the congregation and assembly.",
    "hash": "10d3fa48265a1b6522685089afd039e39f7d6af4d57e1a5c6826abc0062888eb"
  },
  {
    "id": "PRO.5.15",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 15,
    "text": "Drink waters out of thine own cistern, and running waters out of thine own well.",
    "hash": "b32627a9b29c78c84ac4132585ff132e51de197152f4de4f1f2f196effc794de"
  },
  {
    "id": "PRO.5.16",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 16,
    "text": "Let thy fountains be dispersed abroad, {and} rivers of waters in the streets.",
    "hash": "4c297b047f039e81c684fe8bbb82193d372e262e1c5fa4d3719b46427b8739df"
  },
  {
    "id": "PRO.5.17",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 17,
    "text": "Let them be only thine own, and not strangers' with thee.",
    "hash": "922acb8cf85dcbfd7d7cb8a86c43a7b32978f1a895b675734efb135366348d2d"
  },
  {
    "id": "PRO.5.18",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 18,
    "text": "Let thy fountain be blessed: and rejoice with the wife of thy youth.",
    "hash": "c6965fc1fabb471234a78a8f247deac2de0e3e75b7dd6f465a2d25b636ba37bb"
  },
  {
    "id": "PRO.5.19",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 19,
    "text": "{Let her be as} the loving hind and pleasant roe; let her breasts satisfy thee at all times; and be thou ravished always with her love. {satisfy...: Heb. water thee} {be thou...: Heb. err thou always in her love}",
    "hash": "44f7eac096c3703f48de4792a4be1cce57e3dda645f118202ab815217b517adc"
  },
  {
    "id": "PRO.5.20",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 20,
    "text": "And why wilt thou, my son, be ravished with a strange woman, and embrace the bosom of a stranger?",
    "hash": "d675ae78c989222980536bd7d17ac5e20e60e2c4e28be9178299b383fb0f6477"
  },
  {
    "id": "PRO.5.21",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 21,
    "text": "For the ways of man {are} before the eyes of the LORD, and he pondereth all his goings.",
    "hash": "81b815a2e41e9bd13e5d37c4e9866820d7e0ce1b36b92804f862c7b6c4ca4cc3"
  },
  {
    "id": "PRO.5.22",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 22,
    "text": "His own iniquities shall take the wicked himself, and he shall be holden with the cords of his sins. {sins: Heb. sin}",
    "hash": "871fdcc4298b520108559d780fba3812f95cf5c9681e609379ba1453e720649d"
  },
  {
    "id": "PRO.5.23",
    "book": "Proverbs",
    "bookNum": 20,
    "bookAbbrev": "PRO",
    "chapter": 5,
    "verse": 23,
    "text": "He shall die without instruction; and in the greatness of his folly he shall go astray.",
    "hash": "76fc71d27e150191276680337e1e10f5d54be7d7ce38eb5df204f9c24b40ae7d"
  }
]