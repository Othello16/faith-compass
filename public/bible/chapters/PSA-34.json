[
  {
    "id": "PSA.34.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 1,
    "text": "[{A Psalm} of David, when he changed his behaviour before Abimelech; who drove him away, and he departed.] I will bless the LORD at all times: his praise {shall} continually {be} in my mouth. {Abimelech: or, Achish}",
    "hash": "b3f0ca5294a697350dc9eb181e1f46b7d2fb890c33fc582d494b1df5be7c98d9"
  },
  {
    "id": "PSA.34.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 2,
    "text": "My soul shall make her boast in the LORD: the humble shall hear {thereof}, and be glad.",
    "hash": "12a5f5aaf8d98d2250a4ea63fb4aec701af199170a8d4be209a7e53c98c0d03f"
  },
  {
    "id": "PSA.34.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 3,
    "text": "O magnify the LORD with me, and let us exalt his name together.",
    "hash": "d24d56516dfe9c4c5a21fb1661b95924836a605e01aa87acb8167a911263c2ad"
  },
  {
    "id": "PSA.34.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 4,
    "text": "I sought the LORD, and he heard me, and delivered me from all my fears.",
    "hash": "f9e16f84415d36da1be513018ca572db0929bba6ab97acf484c3380a0b495b31"
  },
  {
    "id": "PSA.34.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 5,
    "text": "They looked unto him, and were lightened: and their faces were not ashamed. {were lightened: or, they flowed unto him}",
    "hash": "2bef5461128cd75843f21117e206a2b38015b14f41f269d56acd1d16be55f481"
  },
  {
    "id": "PSA.34.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 6,
    "text": "This poor man cried, and the LORD heard {him}, and saved him out of all his troubles.",
    "hash": "193767114a78e63ebf5a8530e419de817b5797709d184f5e7ec436a6f6778a47"
  },
  {
    "id": "PSA.34.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 7,
    "text": "The angel of the LORD encampeth round about them that fear him, and delivereth them.",
    "hash": "82e20eaa20f4d458e14b1fd048814fe3ec8fa9c3285be06ed3e51510ac3bbf7b"
  },
  {
    "id": "PSA.34.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 8,
    "text": "O taste and see that the LORD {is} good: blessed {is} the man {that} trusteth in him.",
    "hash": "b86eea741b5d5e80913fd4479f3608786957e186f1dd41edd0ab41901550f6da"
  },
  {
    "id": "PSA.34.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 9,
    "text": "O fear the LORD, ye his saints: for {there is} no want to them that fear him.",
    "hash": "72ac0c5d6c21af5dc900acb8724d5471be5b4b35f34c65c423d4e7699844df98"
  },
  {
    "id": "PSA.34.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 10,
    "text": "The young lions do lack, and suffer hunger: but they that seek the LORD shall not want any good {thing}.",
    "hash": "2403d9c2122044e7cb4beed3986c880355fd56a0123bed4d2b9c7c01d90f512b"
  },
  {
    "id": "PSA.34.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 11,
    "text": "Come, ye children, hearken unto me: I will teach you the fear of the LORD.",
    "hash": "dc920dd06f109fc0ca33721ffb14952d5c2a9a4b62085ac92c04569bf914230a"
  },
  {
    "id": "PSA.34.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 12,
    "text": "What man {is he that} desireth life, {and} loveth {many} days, that he may see good?",
    "hash": "de824505e02df2a8baa9b82bea7f3e745d63068c18f9c9d53c42dc203f77f463"
  },
  {
    "id": "PSA.34.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 13,
    "text": "Keep thy tongue from evil, and thy lips from speaking guile.",
    "hash": "e4a3788c09fc0ec0a42fc36c0b8183163ae8136b2b85865f9e56c85839cc9010"
  },
  {
    "id": "PSA.34.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 14,
    "text": "Depart from evil, and do good; seek peace, and pursue it.",
    "hash": "ab3e363b23da4e7928bc11916688b21cc1c20e7f9f4cd5127afbcb81f7c40e23"
  },
  {
    "id": "PSA.34.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 15,
    "text": "The eyes of the LORD {are} upon the righteous, and his ears {are open} unto their cry.",
    "hash": "e5dbcc7bdb54d546aa0eade483e6304e1c4994e1ad43cf026c29bcd3b62e8c8f"
  },
  {
    "id": "PSA.34.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 16,
    "text": "The face of the LORD {is} against them that do evil, to cut off the remembrance of them from the earth.",
    "hash": "5094506a3240ee2462586674acec97df9d33694e5bf44b8e528337c2136ed596"
  },
  {
    "id": "PSA.34.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 17,
    "text": "{The righteous} cry, and the LORD heareth, and delivereth them out of all their troubles.",
    "hash": "8501f5ec2a5d066ed81f5ea21a56e92e1bdfccbf01f9cd675b10b3637ff2ebe5"
  },
  {
    "id": "PSA.34.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 18,
    "text": "The LORD {is} nigh unto them that are of a broken heart; and saveth such as be of a contrite spirit. {unto...: Heb. to the broken of heart} {of a contrite...: Heb. contrite of spirit}",
    "hash": "8d101aef5fe35a5558f6570cee4a894ca4f645c6f3dcadec65ee05a58cee9a5a"
  },
  {
    "id": "PSA.34.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 19,
    "text": "Many {are} the afflictions of the righteous: but the LORD delivereth him out of them all.",
    "hash": "733a32e4b3b80f409a9344d1e589ec277ca7aad52cfeadbdce8d3ac3ce05cb7c"
  },
  {
    "id": "PSA.34.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 20,
    "text": "He keepeth all his bones: not one of them is broken.",
    "hash": "7864e12cd4d49d4f0ab0760f9fab614ddd3937708c56f4545ae2eb46003d59c1"
  },
  {
    "id": "PSA.34.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 21,
    "text": "Evil shall slay the wicked: and they that hate the righteous shall be desolate. {desolate: or, guilty}",
    "hash": "f89218686bdd7498e20fba39277017dc973cc2e7fd81880d1e377c97928dc020"
  },
  {
    "id": "PSA.34.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 34,
    "verse": 22,
    "text": "The LORD redeemeth the soul of his servants: and none of them that trust in him shall be desolate. {desolate: or, guilty}",
    "hash": "4d519cea70bd3526de5405cc8971a6789cd56bb59aec10d426a33aa4b291cee4"
  }
]