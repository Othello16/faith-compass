[
  {
    "id": "PSA.129.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 1,
    "text": "[A Song of degrees.] Many a time have they afflicted me from my youth, may Israel now say: {Many...: or, Much}",
    "hash": "a04f707c321dc74e07a2817ffe087d306912640e1235ef7cfeaae95d689f3a4c"
  },
  {
    "id": "PSA.129.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 2,
    "text": "Many a time have they afflicted me from my youth: yet they have not prevailed against me. {Many...: or, Much}",
    "hash": "f6b69dada8bbb3316f2de61aa3b7dc7dcc87a6b21af601de9cdd8794237bdbe9"
  },
  {
    "id": "PSA.129.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 3,
    "text": "The plowers plowed upon my back: they made long their furrows.",
    "hash": "6135a37f8c66f76a4ec19e49807c6eeee4a4b05f2627e3e364b19f27445ca4a8"
  },
  {
    "id": "PSA.129.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 4,
    "text": "The LORD {is} righteous: he hath cut asunder the cords of the wicked.",
    "hash": "7f735f60fb849f8d7124e46ad9daaaef3948a80aea94b92957b582ac3048c40e"
  },
  {
    "id": "PSA.129.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 5,
    "text": "Let them all be confounded and turned back that hate Zion.",
    "hash": "09956dc537f87b69b752e8726dfc418e92306fc1d214eb6b6220aadf8b8e5dc2"
  },
  {
    "id": "PSA.129.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 6,
    "text": "Let them be as the grass {upon} the housetops, which withereth afore it groweth up:",
    "hash": "585ff306a6fd5295f5af563d2a143b19e81cf8ba49ccf8524417cdabe3eb7ca2"
  },
  {
    "id": "PSA.129.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 7,
    "text": "Wherewith the mower filleth not his hand; nor he that bindeth sheaves his bosom.",
    "hash": "02964281d1c394610696f2cd75d70f8d0297b7e75b9c1eea74dc503c54428259"
  },
  {
    "id": "PSA.129.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 129,
    "verse": 8,
    "text": "Neither do they which go by say, The blessing of the LORD {be} upon you: we bless you in the name of the LORD.",
    "hash": "877cda30dfd76602fa07dd2f31e5c8086b8b3031857ecd9c38cb3259d67de8f7"
  }
]