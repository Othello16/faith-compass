[
  {
    "id": "1CH.1.1",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 1,
    "text": "Adam, Sheth, Enosh,",
    "hash": "77e62a048f710995b470fdfee5c10527da42b1c629aadbecd570fdbdb6e35052"
  },
  {
    "id": "1CH.1.2",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 2,
    "text": "Kenan, Mahalaleel, Jered,",
    "hash": "1aab6f993b730b1977b48a711a74cf044224ca99ac5d5bdde8a1ee65b15cf46a"
  },
  {
    "id": "1CH.1.3",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 3,
    "text": "Henoch, Methuselah, Lamech,",
    "hash": "548811845aa1484e672f8fe972e721a492d77cada808a277ead1912cce975ee2"
  },
  {
    "id": "1CH.1.4",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 4,
    "text": "Noah, Shem, Ham, and Japheth.",
    "hash": "4f284cd3717cb55be029ea50ff59fb596483e6c6a23dc24bc9bdab9990eddd31"
  },
  {
    "id": "1CH.1.5",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 5,
    "text": "The sons of Japheth; Gomer, and Magog, and Madai, and Javan, and Tubal, and Meshech, and Tiras.",
    "hash": "fa4fdff9ed1db4656702991202d6bf60dc73b3fdfe8ac7ba9785780378a908af"
  },
  {
    "id": "1CH.1.6",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 6,
    "text": "And the sons of Gomer; Ashchenaz, and Riphath, and Togarmah. {Riphath: or, Diphath as it is in some copies}",
    "hash": "62543cb112f4376d2db216bbdb2a2665cf418a529fad0b890d70257367be7dfb"
  },
  {
    "id": "1CH.1.7",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 7,
    "text": "And the sons of Javan; Elishah, and Tarshish, Kittim, and Dodanim. {Dodanim: or, Rodanim, according to some copies}",
    "hash": "39351057f01788cc782e14a7c73d5219bf629ec112af0ee005ec26b9c74083e2"
  },
  {
    "id": "1CH.1.8",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 8,
    "text": "The sons of Ham; Cush, and Mizraim, Put, and Canaan.",
    "hash": "dbf490b19037d27e7e4893f6d981be96cad8bc50b56cceec86a30615654e6933"
  },
  {
    "id": "1CH.1.9",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 9,
    "text": "And the sons of Cush; Seba, and Havilah, and Sabta, and Raamah, and Sabtecha. And the sons of Raamah; Sheba, and Dedan.",
    "hash": "b7992143befda1533e13c95c40917841e14b8244641f7e1ace1bfc3c91bc09f2"
  },
  {
    "id": "1CH.1.10",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 10,
    "text": "And Cush begat Nimrod: he began to be mighty upon the earth.",
    "hash": "4054811e58800166436c5456dd18b3969e0db5a83a2d159c5a2af6109b696847"
  },
  {
    "id": "1CH.1.11",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 11,
    "text": "And Mizraim begat Ludim, and Anamim, and Lehabim, and Naphtuhim,",
    "hash": "1dcb9ab5c027e74a2e8b32dc906874120617bb88a704b4098d60dcbca56df0db"
  },
  {
    "id": "1CH.1.12",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 12,
    "text": "And Pathrusim, and Casluhim, (of whom came the Philistines,) and Caphthorim.",
    "hash": "f7ef57ce1066d924fbb57cfe4e40929bd55bbe49bc95d320b34f9c2180374187"
  },
  {
    "id": "1CH.1.13",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 13,
    "text": "And Canaan begat Zidon his firstborn, and Heth,",
    "hash": "36cd8f66fe0ae9c070c3658d0968d74f273369969cbd9b7ca883f3c4e6e1e9ed"
  },
  {
    "id": "1CH.1.14",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 14,
    "text": "The Jebusite also, and the Amorite, and the Girgashite,",
    "hash": "1206c92a35902b70823c5ba82f44d7d8ba462f7d843ab4f7c14abced30aad810"
  },
  {
    "id": "1CH.1.15",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 15,
    "text": "And the Hivite, and the Arkite, and the Sinite,",
    "hash": "7af4cbf3460c5ee3d9ad349593ef72b0e845016721f96cd7b4c15ca542ca20d9"
  },
  {
    "id": "1CH.1.16",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 16,
    "text": "And the Arvadite, and the Zemarite, and the Hamathite.",
    "hash": "1f53d15929bbd6b6daf8e68abd0e76f68421142de1708d01483105ed37ef5f01"
  },
  {
    "id": "1CH.1.17",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 17,
    "text": "The sons of Shem; Elam, and Asshur, and Arphaxad, and Lud, and Aram, and Uz, and Hul, and Gether, and Meshech. {Meshech: or, Mash}",
    "hash": "8d879c11516edeefe1d5a68c131c20a5e47578874bbbcf7205b9831c6b5b6904"
  },
  {
    "id": "1CH.1.18",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 18,
    "text": "And Arphaxad begat Shelah, and Shelah begat Eber.",
    "hash": "1d904cffd9e83ae9de1392a99dd8e62d4865df7144586514e15c9156ae08b684"
  },
  {
    "id": "1CH.1.19",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 19,
    "text": "And unto Eber were born two sons: the name of the one {was} Peleg; because in his days the earth was divided: and his brother's name {was} Joktan. {Peleg: that is, division}",
    "hash": "612e1e3f75e84e0d1c6ac8431849e5b62b6368ce5b796525f1e65c139eaacef8"
  },
  {
    "id": "1CH.1.20",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 20,
    "text": "And Joktan begat Almodad, and Sheleph, and Hazarmaveth, and Jerah,",
    "hash": "c4d308c46b0fdd1f59b3abe0dd05429ec42f65dda31b41e75cd723e43621056c"
  },
  {
    "id": "1CH.1.21",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 21,
    "text": "Hadoram also, and Uzal, and Diklah,",
    "hash": "ca1a957ad41c40e77fbe3a600cedc1b6d24353fc3494a995dc0750bf38b61af8"
  },
  {
    "id": "1CH.1.22",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 22,
    "text": "And Ebal, and Abimael, and Sheba,",
    "hash": "88dbe74e3fdf8ef0170aa7b25c472ff3504df24bb0e05b56168ab55924fbef43"
  },
  {
    "id": "1CH.1.23",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 23,
    "text": "And Ophir, and Havilah, and Jobab. All these {were} the sons of Joktan.",
    "hash": "03716b26d9af29676924b54b25f45e2bddb11658c8de2b0d63ac189bc2c97444"
  },
  {
    "id": "1CH.1.24",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 24,
    "text": "Shem, Arphaxad, Shelah,",
    "hash": "4bcdee41d27a95f8f396a0f39143316896b2a9c85a70a7c92331106078c840f6"
  },
  {
    "id": "1CH.1.25",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 25,
    "text": "Eber, Peleg, Reu,",
    "hash": "a46283b68c41c82f5f3b35efc3db6fc6b4eb2e7c81c63531331d885b5a3a871d"
  },
  {
    "id": "1CH.1.26",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 26,
    "text": "Serug, Nahor, Terah,",
    "hash": "22ec3b3426c3504311ba630f273569b065cca46b6d50666f9f42de6a9fe2f62e"
  },
  {
    "id": "1CH.1.27",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 27,
    "text": "Abram; the same {is} Abraham.",
    "hash": "3bef71a5d9ada0cfd86b7bc2b05287eeabf60f13eff37b2369ff017f5e14e8f9"
  },
  {
    "id": "1CH.1.28",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 28,
    "text": "The sons of Abraham; Isaac, and Ishmael.",
    "hash": "3c4271add5e96500aea212d7294483bcf116ff3e9e62e278df4ecafdc834190d"
  },
  {
    "id": "1CH.1.29",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 29,
    "text": "These {are} their generations: The firstborn of Ishmael, Nebaioth; then Kedar, and Adbeel, and Mibsam,",
    "hash": "f8493f91d163431edb4efca318190e44e247c711fafc0e84a78289f26f1024c9"
  },
  {
    "id": "1CH.1.30",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 30,
    "text": "Mishma, and Dumah, Massa, Hadad, and Tema, {Hadad: also called, Hadar}",
    "hash": "f5f705f3cac207da6ce3b99dc1635a2e3318f86a849a54690dbd4ba58f8c4c6b"
  },
  {
    "id": "1CH.1.31",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 31,
    "text": "Jetur, Naphish, and Kedemah. These are the sons of Ishmael.",
    "hash": "c55aaf4b5f35950f03ba288406d8e8776bee1e380111738f4457905b6edb90ac"
  },
  {
    "id": "1CH.1.32",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 32,
    "text": "Now the sons of Keturah, Abraham's concubine: she bare Zimran, and Jokshan, and Medan, and Midian, and Ishbak, and Shuah. And the sons of Jokshan; Sheba, and Dedan.",
    "hash": "e369a617398eeff5e505fa5697e60c77e0745f53c6a8d915801e320ec69052a1"
  },
  {
    "id": "1CH.1.33",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 33,
    "text": "And the sons of Midian; Ephah, and Epher, and Henoch, and Abida, and Eldaah. All these {are} the sons of Keturah.",
    "hash": "a5532f6ff9b23efdaf2fa4f06c12882b82633e4e8cd34c98b60c2ed12fd322a7"
  },
  {
    "id": "1CH.1.34",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 34,
    "text": "And Abraham begat Isaac. The sons of Isaac; Esau and Israel.",
    "hash": "e59ebc3ec07b7401c5d96bb112bc6c19cedc98275510e119ddd526700b1905b0"
  },
  {
    "id": "1CH.1.35",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 35,
    "text": "The sons of Esau; Eliphaz, Reuel, and Jeush, and Jaalam, and Korah.",
    "hash": "ec818bf707c5c3c66ed2f6ae66ae75393faf571492521ff5d85014442df34921"
  },
  {
    "id": "1CH.1.36",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 36,
    "text": "The sons of Eliphaz; Teman, and Omar, Zephi, and Gatam, Kenaz, and Timna, and Amalek. {Zephi: or, Zepho}",
    "hash": "1fd4ccd906c72b1084689db3a8a54ee1bd613cd5bf32c9ed96a4310f4c6cced8"
  },
  {
    "id": "1CH.1.37",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 37,
    "text": "The sons of Reuel; Nahath, Zerah, Shammah, and Mizzah.",
    "hash": "f46940150b1601285eb1417d77b1f62a204e8fee479cb0f1afe9b76fdb9d8207"
  },
  {
    "id": "1CH.1.38",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 38,
    "text": "And the sons of Seir; Lotan, and Shobal, and Zibeon, and Anah, and Dishon, and Ezer, and Dishan.",
    "hash": "806d32aadf5d99f9312d1d1c4a3949ea57daedad3060ee8034e4591e46d54307"
  },
  {
    "id": "1CH.1.39",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 39,
    "text": "And the sons of Lotan; Hori, and Homam: and Timna {was} Lotan's sister. {Homam: or, Hemam}",
    "hash": "d0ec1ab113a0fb47fd57a63514734030b79f71875e92b60b60cd3bc6c4f3eded"
  },
  {
    "id": "1CH.1.40",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 40,
    "text": "The sons of Shobal; Alian, and Manahath, and Ebal, Shephi, and Onam. And the sons of Zibeon; Aiah, and Anah. {Alian: also called, Alvan} {Shephi: also called, Shepho}",
    "hash": "ae8d2862ce15daee9af933e827a31ccaa4bc8e34d2f2e93a241fa60cb37ddc35"
  },
  {
    "id": "1CH.1.41",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 41,
    "text": "The sons of Anah; Dishon. And the sons of Dishon; Amram, and Eshban, and Ithran, and Cheran. {Amram: or, Hemdan}",
    "hash": "3e27d28db946755809a614d2d5893bd5ba9daae6afd3c389e77e598128db8a84"
  },
  {
    "id": "1CH.1.42",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 42,
    "text": "The sons of Ezer; Bilhan, and Zavan, {and} Jakan. The sons of Dishan; Uz, and Aran. {Jakan: or, Akan}",
    "hash": "6a3e5bb617cf2084f6f1076f877aa6921ba0c0937bbbff98ad692e9fc5b2bbff"
  },
  {
    "id": "1CH.1.43",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 43,
    "text": "Now these {are} the kings that reigned in the land of Edom before {any} king reigned over the children of Israel; Bela the son of Beor: and the name of his city {was} Dinhabah.",
    "hash": "039ea6e7353bf10302696b371422117d68ef5167c90cc678cd17e534d5ccab94"
  },
  {
    "id": "1CH.1.44",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 44,
    "text": "And when Bela was dead, Jobab the son of Zerah of Bozrah reigned in his stead.",
    "hash": "062b286e18f0e28c5c366d2de6d2c041fb5a79df7bf74eeaf47de6c5f44877f3"
  },
  {
    "id": "1CH.1.45",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 45,
    "text": "And when Jobab was dead, Husham of the land of the Temanites reigned in his stead.",
    "hash": "a50ea34b85e1b69611a647fea952ee4a025ec64a25c563331f62e2e9e6aadbc1"
  },
  {
    "id": "1CH.1.46",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 46,
    "text": "And when Husham was dead, Hadad the son of Bedad, which smote Midian in the field of Moab, reigned in his stead: and the name of his city {was} Avith.",
    "hash": "eb0a1fcd10b010ec2367b5ebca2a0cecff98b80ea34526e2ea7eeb0f596872b4"
  },
  {
    "id": "1CH.1.47",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 47,
    "text": "And when Hadad was dead, Samlah of Masrekah reigned in his stead.",
    "hash": "df1e8f90ec3393e7c29d7eea0a7578df4d6dcb82242adfdc0e47da2f7776c552"
  },
  {
    "id": "1CH.1.48",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 48,
    "text": "And when Samlah was dead, Shaul of Rehoboth by the river reigned in his stead.",
    "hash": "3e47edf96e1de714c3797aff0032b506b74aacb22bea356d431ef076db2c1322"
  },
  {
    "id": "1CH.1.49",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 49,
    "text": "And when Shaul was dead, Baalhanan the son of Achbor reigned in his stead.",
    "hash": "cb2bc312a8d63e2e7edb9e9e4dace292fab85fb8a0cc5a05486f7418bb634608"
  },
  {
    "id": "1CH.1.50",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 50,
    "text": "And when Baalhanan was dead, Hadad reigned in his stead: and the name of his city {was} Pai; and his wife's name {was} Mehetabel, the daughter of Matred, the daughter of Mezahab. {Hadad: or, Hadar} {Pai: or, Pau}",
    "hash": "880e03336a844e5bc9b2453e50640265c0a7b3df2095895000d8f18c4d8099d6"
  },
  {
    "id": "1CH.1.51",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 51,
    "text": "Hadad died also. And the dukes of Edom were; duke Timnah, duke Aliah, duke Jetheth,",
    "hash": "ec85ad95ae65d5e4cd19522056c54e7cddd4909e468aaa7b63699ae21a3090bf"
  },
  {
    "id": "1CH.1.52",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 52,
    "text": "Duke Aholibamah, duke Elah, duke Pinon,",
    "hash": "604ab8ce0082d2b9f487a52f9f18f148a54c1f8b531ea849aca86a9103375fb8"
  },
  {
    "id": "1CH.1.53",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 53,
    "text": "Duke Kenaz, duke Teman, duke Mibzar,",
    "hash": "2d1307dfb3fa154271304b29fc63060b0cdc1eb119d5d8e0c9575f42064adb0d"
  },
  {
    "id": "1CH.1.54",
    "book": "1 Chronicles",
    "bookNum": 13,
    "bookAbbrev": "1CH",
    "chapter": 1,
    "verse": 54,
    "text": "Duke Magdiel, duke Iram. These {are} the dukes of Edom.",
    "hash": "b2e48ab741c5914563283de7ab76d81622297055bc10fd3744bdb45e46da12f1"
  }
]