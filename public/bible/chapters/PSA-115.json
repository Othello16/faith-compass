[
  {
    "id": "PSA.115.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 1,
    "text": "Not unto us, O LORD, not unto us, but unto thy name give glory, for thy mercy, {and} for thy truth's sake.",
    "hash": "d25b935ca45fc7c005229197ca39450bcb6d2c414543fcf4ea99b882717835f0"
  },
  {
    "id": "PSA.115.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 2,
    "text": "Wherefore should the heathen say, Where {is} now their God?",
    "hash": "63b7e1dfdc2a983247327aabf7620adbebae642ecef5d7f62b3e5504799128c6"
  },
  {
    "id": "PSA.115.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 3,
    "text": "But our God {is} in the heavens: he hath done whatsoever he hath pleased.",
    "hash": "c737029dde89515ad67be7c2c4e0eec92a54c85c8af1a284d97378cc7abc66ef"
  },
  {
    "id": "PSA.115.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 4,
    "text": "Their idols {are} silver and gold, the work of men's hands.",
    "hash": "98500dc5d6ffe1c38fca45a7da18b91678b199f53ae3f021b09a84739aaf36d9"
  },
  {
    "id": "PSA.115.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 5,
    "text": "They have mouths, but they speak not: eyes have they, but they see not:",
    "hash": "1aff3cc58ed521b2723755f115c85814c7b990a85873eb4e0e90b99a47b1e24e"
  },
  {
    "id": "PSA.115.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 6,
    "text": "They have ears, but they hear not: noses have they, but they smell not:",
    "hash": "3180bc4d83f993613c603b2bd0a0d90639c3d85af214a5a37bfa1ad3d8f68d49"
  },
  {
    "id": "PSA.115.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 7,
    "text": "They have hands, but they handle not: feet have they, but they walk not: neither speak they through their throat.",
    "hash": "119d80734dfd8cc163fe182ac148e2f699466e78e322dc91376fefa2c39dc8ec"
  },
  {
    "id": "PSA.115.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 8,
    "text": "They that make them are like unto them; {so is} every one that trusteth in them.",
    "hash": "a9c3fbd07140cbf6156add6cb610a9e2f094d1c91155ae73fc9d874f7b25ce40"
  },
  {
    "id": "PSA.115.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 9,
    "text": "O Israel, trust thou in the LORD: he {is} their help and their shield.",
    "hash": "9fe0601ae795b8683c75e02d6b7219e09e6363a93363d4b087b28ec178505da7"
  },
  {
    "id": "PSA.115.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 10,
    "text": "O house of Aaron, trust in the LORD: he {is} their help and their shield.",
    "hash": "1e94478b6da039cc7128fd4d43299107b9620311f5278e483e5574e5fa367d26"
  },
  {
    "id": "PSA.115.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 11,
    "text": "Ye that fear the LORD, trust in the LORD: he {is} their help and their shield.",
    "hash": "eada16a16e46fda786b37346db39999795596ff4335dd0036c8896ac3f0eb01f"
  },
  {
    "id": "PSA.115.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 12,
    "text": "The LORD hath been mindful of us: he will bless {us}; he will bless the house of Israel; he will bless the house of Aaron.",
    "hash": "bcb8aefcd7893e59ae8d7f2eb560bf135b602732115139d778bd05d1a3dbaa2d"
  },
  {
    "id": "PSA.115.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 13,
    "text": "He will bless them that fear the LORD, {both} small and great. {and: Heb. with}",
    "hash": "14f5cf036324f334e7882a6b95a86be30dc53be19805b5a9d715c3c935a13c85"
  },
  {
    "id": "PSA.115.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 14,
    "text": "The LORD shall increase you more and more, you and your children.",
    "hash": "d383fdb3b60482ca20cfd81e36f03987c27f496bc2e935e28d83915d78363b80"
  },
  {
    "id": "PSA.115.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 15,
    "text": "Ye {are} blessed of the LORD which made heaven and earth.",
    "hash": "b003d817be75d229a817e2195a26f78322fa112d9399f2a5df664e2b6162d794"
  },
  {
    "id": "PSA.115.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 16,
    "text": "The heaven, {even} the heavens, {are} the LORD'S: but the earth hath he given to the children of men.",
    "hash": "2b25ef4b129b8b26bae512e0e1aa9e5a6761272012c01df7a7627fe1604942e4"
  },
  {
    "id": "PSA.115.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 17,
    "text": "The dead praise not the LORD, neither any that go down into silence.",
    "hash": "722992df2a23f49b10d27dfa9c6c4ce9da628a0e1beb9dc735db6222713dbe52"
  },
  {
    "id": "PSA.115.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 115,
    "verse": 18,
    "text": "But we will bless the LORD from this time forth and for evermore. Praise the LORD.",
    "hash": "545c638b0b21b5396bb28eacb7ede879182d04ab9fd8243c63ff70c0d65ff55c"
  }
]