[
  {
    "id": "PSA.118.1",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 1,
    "text": "O give thanks unto the LORD; for {he is} good: because his mercy {endureth} for ever.",
    "hash": "de7af9ab27951513c0d6ecd7549dfdefc8106e0a378aa2232fbd41515c456108"
  },
  {
    "id": "PSA.118.2",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 2,
    "text": "Let Israel now say, that his mercy {endureth} for ever.",
    "hash": "e7d85dd4dbfe6216a98279ae3d696cedff081d7a72e4d9c54e244d75f5176331"
  },
  {
    "id": "PSA.118.3",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 3,
    "text": "Let the house of Aaron now say, that his mercy {endureth} for ever.",
    "hash": "2c9f2b187686c992f69fc182ddfbf0926e495375a2ef7e2592d081d623c508fe"
  },
  {
    "id": "PSA.118.4",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 4,
    "text": "Let them now that fear the LORD say, that his mercy {endureth} for ever.",
    "hash": "46b0c2a8d6dc59b9fecc7ccea3a54de9e9726713fb2ab1da0e01cfe8f9431334"
  },
  {
    "id": "PSA.118.5",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 5,
    "text": "I called upon the LORD in distress: the LORD answered me, {and set me} in a large place. {in distress: Heb. out of distress}",
    "hash": "0125fbae2bc1e5748a451a812be4b98e20613fd57b877c7940e00768acd5f3da"
  },
  {
    "id": "PSA.118.6",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 6,
    "text": "The LORD {is} on my side; I will not fear: what can man do unto me? {on...: Heb. for me}",
    "hash": "bbc1658651c256923ee2372b2b1dad83d7c8342f363fb2ca4cdba9b881f4c898"
  },
  {
    "id": "PSA.118.7",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 7,
    "text": "The LORD taketh my part with them that help me: therefore shall I see {my desire} upon them that hate me.",
    "hash": "57b6b5c0a279ef870595b4b6abee82d8082c06e852343f964678ef98bf91d859"
  },
  {
    "id": "PSA.118.8",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 8,
    "text": "{It is} better to trust in the LORD than to put confidence in man.",
    "hash": "052622ef1290cdd5fcac6d60296ae4cfd9f6801f4b9f36e6a5aa3f211005ec5a"
  },
  {
    "id": "PSA.118.9",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 9,
    "text": "{It is} better to trust in the LORD than to put confidence in princes.",
    "hash": "5bdedbdb7a8799b867aff23818022aeaae7cb437af3efbdd362397286c97fb5c"
  },
  {
    "id": "PSA.118.10",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 10,
    "text": "All nations compassed me about: but in the name of the LORD will I destroy them. {destroy...: Heb. cut them off}",
    "hash": "dac81a69a45818b4a2f080d3792f82c4f0f53b5f26635811b63133149db311f2"
  },
  {
    "id": "PSA.118.11",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 11,
    "text": "They compassed me about; yea, they compassed me about: but in the name of the LORD I will destroy them.",
    "hash": "98b1db9240154d33f101d9ba43dc3c1c3eaafdba0e938512b7b65348dfb07b24"
  },
  {
    "id": "PSA.118.12",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 12,
    "text": "They compassed me about like bees; they are quenched as the fire of thorns: for in the name of the LORD I will destroy them. {destroy: Heb. cut down}",
    "hash": "30310c11184fb3913491815dc7fa164fd246089084b8650b28b97f2ed778833f"
  },
  {
    "id": "PSA.118.13",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 13,
    "text": "Thou hast thrust sore at me that I might fall: but the LORD helped me.",
    "hash": "90d144d1c366b962372abe6d0f31226834d0f329aaa9795c228f81e5d6217180"
  },
  {
    "id": "PSA.118.14",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 14,
    "text": "The LORD {is} my strength and song, and is become my salvation.",
    "hash": "abd70a3769a3baa6bf4ff8170bb1ef52bee3db081958bc72d5ffd62c3ac927e7"
  },
  {
    "id": "PSA.118.15",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 15,
    "text": "The voice of rejoicing and salvation {is} in the tabernacles of the righteous: the right hand of the LORD doeth valiantly.",
    "hash": "ea7e28265d8ff95265e7bc29635ea6c3708c7c77feceeceafc6f4fac0fef0fb7"
  },
  {
    "id": "PSA.118.16",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 16,
    "text": "The right hand of the LORD is exalted: the right hand of the LORD doeth valiantly.",
    "hash": "ded879055d54189846e0060ae7ecfdf9cf9eefd8421805beea0370adb424825c"
  },
  {
    "id": "PSA.118.17",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 17,
    "text": "I shall not die, but live, and declare the works of the LORD.",
    "hash": "4234fbdea5946d5dcf2225f3d1fafa8881189bdce5f6d2a7a077c3c1adf2c60e"
  },
  {
    "id": "PSA.118.18",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 18,
    "text": "The LORD hath chastened me sore: but he hath not given me over unto death.",
    "hash": "e6ddc0705e12f83bf859fcf27909395b3b1ae2e9ba75771004fef249be716f29"
  },
  {
    "id": "PSA.118.19",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 19,
    "text": "Open to me the gates of righteousness: I will go into them, {and} I will praise the LORD:",
    "hash": "7e3a57b67bc0ff19f47e84258aba33337f59e9333975ed764dfdb773a1e4c1b7"
  },
  {
    "id": "PSA.118.20",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 20,
    "text": "This gate of the LORD, into which the righteous shall enter.",
    "hash": "d75270788d6533da53945a7d4451b2418995c8f7886519b1d2ea036e4c5527b2"
  },
  {
    "id": "PSA.118.21",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 21,
    "text": "I will praise thee: for thou hast heard me, and art become my salvation.",
    "hash": "20f9489f8c1d1c1467b3a14b4fd212c3eacad12bfae7bb657691216e9b1666eb"
  },
  {
    "id": "PSA.118.22",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 22,
    "text": "The stone {which} the builders refused is become the head {stone} of the corner.",
    "hash": "d0a5bd1431f927c170b06e8cd338fb7d8d2e0859d1f7a4905c09f3f44c431c9a"
  },
  {
    "id": "PSA.118.23",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 23,
    "text": "This is the LORD'S doing; it {is} marvellous in our eyes. {the LORD's...: Heb. from the LORD}",
    "hash": "a8f927b713923a45e06c9d89072d31600da41017c996d15f64fb4de3a87b48fd"
  },
  {
    "id": "PSA.118.24",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 24,
    "text": "This {is} the day {which} the LORD hath made; we will rejoice and be glad in it.",
    "hash": "8a033854ae53bcf3044d05aeaa9fcac41303f28d5ac8221f2b45a2a024a11509"
  },
  {
    "id": "PSA.118.25",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 25,
    "text": "Save now, I beseech thee, O LORD: O LORD, I beseech thee, send now prosperity.",
    "hash": "f7f1e45a06d23be7cb126804912d71a7444b092cc67ac368ae6761871f87594e"
  },
  {
    "id": "PSA.118.26",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 26,
    "text": "Blessed {be} he that cometh in the name of the LORD: we have blessed you out of the house of the LORD.",
    "hash": "7cf18afd42d1d357697f75ea7bad89c6441ec2732dd503ba908c385756f9fe1a"
  },
  {
    "id": "PSA.118.27",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 27,
    "text": "God {is} the LORD, which hath shewed us light: bind the sacrifice with cords, {even} unto the horns of the altar.",
    "hash": "11c5b9afe8cd7269d06380822b7d2b7f86fb384ca76f5d17deb625dd5c7d1f64"
  },
  {
    "id": "PSA.118.28",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 28,
    "text": "Thou {art} my God, and I will praise thee: {thou art} my God, I will exalt thee.",
    "hash": "3ae8255a9f62342020f0e410479980320da937d8449bae3c9f46073ed8d4a45b"
  },
  {
    "id": "PSA.118.29",
    "book": "Psalms",
    "bookNum": 19,
    "bookAbbrev": "PSA",
    "chapter": 118,
    "verse": 29,
    "text": "O give thanks unto the LORD; for {he is} good: for his mercy {endureth} for ever.",
    "hash": "4a3205c28e2c2cfaae20ff8b51d02c1776e003e44361c380df49a1d7902c9ff4"
  }
]